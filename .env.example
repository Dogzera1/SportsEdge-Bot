# ── SportsEdge Bot — MMA Only (Fase 1) ──

# Telegram
TELEGRAM_TOKEN_MMA=           # Token do bot MMA via @BotFather
TELEGRAM_TOKEN_TENNIS=        # Token do bot Tênis via @BotFather

# APIs
CLAUDE_API_KEY=               # Anthropic Claude (claude-sonnet-4-6)
ODDS_API_KEY=                 # OddsPapi free tier — MMA odds (oddspapi.io, 250 req/mês)
THE_ODDS_API_KEY=             # The Odds API — futebol/tênis/mma (the-odds-api.com, 500 req/mês)
API_FOOTBALL_KEY=             # API-Football (api-sports.io) — fixtures sem odds, 100 req/dia grátis
API_FOOTBALL_DAILY_BUDGET=80  # Buffer de segurança (padrão 80 de 100)

# Cache HTTP (TTL por URL)
HTTP_CACHE_DEFAULT_TTL_MS=0              # 0=desligado (ainda faz dedupe in-flight)
HTTP_CACHE_MAX_ENTRIES=500               # limite entradas cache
HTTP_CACHE_THEODDS_TTL_MS=14400000       # 4h padrão (The Odds API)
HTTP_CACHE_ODDSPAPI_TOURNAMENTS_TTL_MS=86400000  # 24h (lista tournaments)
HTTP_CACHE_ODDSPAPI_ODDS_TTL_MS=0        # odds OddsPapi (recomendado 0; backoff já controla)
HTTP_CACHE_ODDSPAPI_FIXTURE_TTL_MS=0     # odds-by-fixtures (handicap)

# Servidor
SERVER_PORT=3000
DB_PATH=/data/sportsedge.db  # Railway volume — use sportsedge.db localmente

# Admin
ADMIN_KEY=                    # Header: x-admin-key ou Authorization: Bearer (protege rotas admin)
ADMIN_USER_IDS=               # ID numérico Telegram (obtenha via @userinfobot)

# Bucket gate (rejeita tips em faixas de odds com leak comprovado via roi-by-odds-bucket)
# Formato: "MIN-MAX" separado por vírgula. MIN inclusive, MAX exclusive.
# ODDS_BUCKET_BLOCK=2.20-3.00              # cross-sport (default vazio)
# VALORANT_ODDS_BUCKET_BLOCK=2.20-99       # per-sport override (additive ao global)
# LOL_ODDS_BUCKET_BLOCK=3.00-99
# CS_ODDS_BUCKET_BLOCK=
# TENNIS_ODDS_BUCKET_BLOCK=
# DOTA2_ODDS_BUCKET_BLOCK=
# MMA_ODDS_BUCKET_BLOCK=
# FOOTBALL_ODDS_BUCKET_BLOCK=

# Bucket auto-guard (cron 12h, persiste em DB table odds_bucket_blocklist)
# Auto-block (sport, bucket) quando n≥minN AND ROI≤cutoff AND CLV≤clvCutoff. Auto-restore se ROI recupera.
# ODDS_BUCKET_GUARD_AUTO=true              # default true; setar false desativa o cron
# ODDS_BUCKET_GUARD_MIN_N=30
# ODDS_BUCKET_GUARD_ROI_CUTOFF=-10
# ODDS_BUCKET_GUARD_CLV_CUTOFF=-2
# ODDS_BUCKET_GUARD_ROI_RESTORE=-2
# ODDS_BUCKET_GUARD_DAYS=30

# Pre-match EV bonus (audit-leaks 2026-04-22 mostrou PRE-match com ROI muito
# pior que LIVE em vários sports — odds estáticas viram fantasma quando mercado
# move antes do start). Bonus é aditivo ao EV mínimo já configurado per-sport.
# PRE_MATCH_EV_BONUS=                      # cross-sport (default 0)
# CS_PRE_MATCH_EV_BONUS=5                  # CS PRE -53% vs LIVE +19% (gap 72pp)
# VALORANT_PRE_MATCH_EV_BONUS=4            # Val PRE -44% vs LIVE +12% (gap 56pp)
# LOL_PRE_MATCH_EV_BONUS=4                 # esports PRE -37% vs LIVE +10% (gap 47pp)
# DARTS_PRE_MATCH_EV_BONUS=2               # Darts PRE +9% vs LIVE +49% (gap 40pp, marginal)
# DOTA2_PRE_MATCH_EV_BONUS=
# TENNIS_PRE_MATCH_EV_BONUS=               # tennis gap só 6pp, não justifica
# FOOTBALL_PRE_MATCH_EV_BONUS=

# Stake max cap (audit-leaks mostrou 3u tóxico em esports/cs/tennis — modelo
# overconfident em casos extremos). Clamp final aplicado em applyGlobalRisk.
# MAX_STAKE_UNITS=2.0                      # cross-sport cap (default sem cap)
# CS_MAX_STAKE_UNITS=2.0                   # per-sport override
# ESPORTS_MAX_STAKE_UNITS=2.0              # equivalente a LOL no normSport
# LOL_MAX_STAKE_UNITS=2.0
# TENNIS_MAX_STAKE_UNITS=2.0
# DOTA2_MAX_STAKE_UNITS=
# VALORANT_MAX_STAKE_UNITS=

# MMA override: promove conf=MÉDIA quando IA off + sem trained model mas edge
# determinístico é robusto. Sem isso, override sempre BAIXA → gate BAIXA mata
# todas as tips MMA quando AI_DISABLED=true.
# MMA_OVERRIDE_PROMOTE_EDGE_PP=15          # edge mínimo (pp) pra promover BAIXA→MÉDIA
# MMA_OVERRIDE_PROMOTE_MIN_EV=10           # EV mínimo (%) pra promover

# Gates auto-tune (cron 12h, persiste em DB table gates_runtime_state)
# Auto-ajusta PRE_MATCH_EV_BONUS e MAX_STAKE_UNITS por sport baseado no que o
# audit-leaks mostraria — sem precisar setar envs manualmente. Env per-sport
# manual SEMPRE sobrepõe auto-tune (você mantém override preciso quando quiser).
# GATES_AUTOTUNE_AUTO=true                 # default true; setar false desativa
# GATES_AUTOTUNE_MIN_N=20                  # min sample por (sport, isLive) ou (sport, stakeBucket)
# GATES_AUTOTUNE_DAYS=30                   # janela de avaliação
# GATES_AUTOTUNE_PRE_GAP_PP=20             # gap LIVE-PRE (pp) que dispara +1 bonus
# GATES_AUTOTUNE_PRE_RELEASE_PP=5          # gap menor que isso → -1 bonus (libera)
# GATES_AUTOTUNE_STAKE_ROI_CUTOFF=-25      # bucket com ROI <= isso vira leak
# GATES_AUTOTUNE_MAX_BONUS=8               # cap absoluto pro bonus EV pre-match

# Feature flags (MMA only por defeito)
MMA_ENABLED=true
ESPORTS_ENABLED=false
TENNIS_ENABLED=false          # true para ativar o bot de tênis (requer TELEGRAM_TOKEN_TENNIS e THE_ODDS_API_KEY)
# TENNIS_MIN_ODDS=1.40        # Gate pós-IA: odd mínima (default 1.40, alinhado ao MMA)
# TENNIS_MAX_ODDS=5.00        # Gate pós-IA: odd máxima (default 5.00)
# TENNIS_ISOTONIC_DISABLED=true  # Kill-switch: bypassa lib/tennis-model-isotonic.json
                                 # (overshooting na zona [0.40, 0.55) — ROI -64% bucket 2.20-3.00)
                                 # Não afeta isotonic interno do trained model (tennis-weights.json)

# Meta LoL
LOL_PATCH_META=                  # Ex: "Patch 15.6 — Azir/Corki meta mid, Garen top forte"
PATCH_META_DATE=                 # Ex: 2025-03-19 — auto-atualizado pelo bot via ddragon

# Calibração de thresholds (opcional — ajuste para mais ou menos tips)
# LOL_PREGAME_BLOCK_BO3=true     # true=só analisa Bo1 pré-jogo (maior qualidade) | false=analisa todos pré-jogo
# LOL_EV_THRESHOLD=1.5           # EV mínimo para emitir tip (%) — padrão 1.5, use 1.0 para mais tips
# LOL_PINNACLE_MARGIN=2.5        # Margem mínima vs Pinnacle (pp) — padrão 2.5, use 2.0 para mais tips
# LOL_NO_ODDS_CONVICTION=60      # Convicção mínima sem odds (%) — padrão 60, use 55 para mais tips

# ─────────────────────────────────────────────────────────────────────────
# Football data CSV (football-data.co.uk integration — sem auth)
# ─────────────────────────────────────────────────────────────────────────
# FB_USE_FD_CSV=true                       # default true; false desativa fd_features no Poisson
# FB_DIVERGENCE_GATE=true                  # bloqueia tips 1X2 com divergência grande vs Pinn closing
# FB_DIVERGENCE_MAX_PP=12                  # threshold (default 12pp); >max → skip dispatch
# XG_PER_SOT=0.32                          # conversion factor shots-on-target → xG (lit avg 0.30-0.34)

# ─────────────────────────────────────────────────────────────────────────
# Memory / TTL (anti-leak Maps in-memory)
# ─────────────────────────────────────────────────────────────────────────
# ANALYZED_TTL_MS=259200000                # 72h default; sweep cron 1h remove entries antigas
# MARKET_TIP_SENT_TTL_MS=172800000         # 48h default; dedup MT tips

# ─────────────────────────────────────────────────────────────────────────
# DB Backup (VACUUM INTO snapshot diário)
# ─────────────────────────────────────────────────────────────────────────
# DB_BACKUP_AUTO=true                      # default true; cron 30min checa hora
# DB_BACKUP_HOUR_UTC=4                     # 4h UTC = 1h BRT (madrugada baixa atividade)
# DB_BACKUP_KEEP_DAYS=7                    # retention; deleta backups/sportsedge_*.db mais velhos
# DB_SYNCHRONOUS=NORMAL                    # NORMAL (default WAL+NORMAL) | FULL (durabilidade absoluta)
# DB_SLOW_QUERY_MS=0                       # 0 = off; >0 ativa wrap em prepare() pra log queries lentas
# DAILY_LEAKS_DIGEST_AUTO=true             # cron 1x/dia DM admin com top leaks (n>=20, ROI<=-15%)
# DAILY_LEAKS_DIGEST_HOUR_UTC=13           # 13h UTC = 10h BRT
# DAILY_LEAKS_MIN_N=20
# DAILY_LEAKS_ROI_CUTOFF=-15
# DAILY_LEAKS_DAYS=7
# MT_RESTORE_AUTO=true                     # cron diário sugere remover bloqueados que recuperaram
# MT_RESTORE_HOUR_UTC=14                   # 14h UTC = 11h BRT (1h pós leaks digest)
# MT_RESTORE_MIN_N=30
# MT_RESTORE_DAYS=14
# MT_RESTORE_MIN_ROI=0                     # ROI%
# MT_RESTORE_MIN_CLV=0                     # CLV%
# WEEKLY_DIGEST_AUTO=true                  # default ON; weekly summary 1x/semana DM admin
# WEEKLY_DIGEST_DAY_UTC=1                  # 1=Mon (0=Sun)
# WEEKLY_DIGEST_HOUR_UTC=14                # 14h UTC = 11h BRT
# WEEKLY_DIGEST_DAYS=7                     # janela de stats
# MEM_WATCHDOG_DISABLED=                   # true desativa watchdog
# MEM_WATCHDOG_AUTO=true                   # P95 baseline 7d × 1.3 (default ON)
# MEM_WATCHDOG_AUTO_MARGIN=1.3             # margem multiplicativa sobre P95
# MEM_WATCHDOG_RSS_MB=                     # override hard (sobrepõe auto-tune)
# SAME_PICK_ONLY_DEDUP_SPORTS=             # csv sports onde dedup só bloqueia mesmo pick (raro: arb/parlay)

# ─────────────────────────────────────────────────────────────────────────
# Autonomy / loops defensivos (default ON; opt-out =false)
# ─────────────────────────────────────────────────────────────────────────
# AUTONOMY_DIGEST_AUTO=true                # daily digest 1x/dia DM admins
# AUTONOMY_DIGEST_HOUR_UTC=12              # 12h UTC = 9h BRT
# NIGHTLY_RETRAIN_AUTO=true                # refresh-all-isotonics.js diário
# NIGHTLY_RETRAIN_HOUR_UTC=3               # 3h UTC = 0h BRT
# AUTO_ROLLBACK_ON_REGRESSION=true         # rollback modelo se Brier piora pós-retrain
# BRIER_AUTO_EV_CAP=true                   # reduz EV ceiling quando Brier degrada
# LIVE_RISK_MONITOR_AUTO=true              # auto-void tips live com risco extremo
# AUTO_VOID_STUCK_AUTO=true                # auto-void tips pendentes >48h
# MT_LEAK_GUARD_AUTO=true                  # auto-disable (sport,market) com CLV leak

# ─────────────────────────────────────────────────────────────────────────
# CLV pre-dispatch gate (sharp money entrou no lado oposto = stale)
# ─────────────────────────────────────────────────────────────────────────
# CLV_PREDISPATCH_GATE=true                # default true; gate antes do dispatch
# CLV_PREDISPATCH_THRESHOLD=2.5            # %, odd subiu >X% nos últimos N min = skip
# CLV_PREDISPATCH_WINDOW_MIN=10            # janela de medida (min)
# VELOCITY_WINDOW_MIN=10                   # cross-uso por velocity-tracker

# ─────────────────────────────────────────────────────────────────────────
# Tournament / dedup caps
# ─────────────────────────────────────────────────────────────────────────
# MAX_TIPS_PER_TOURNAMENT_PER_DAY=8        # limite tips por liga/dia (anti-concentração)
# TENNIS_MARKET_MAX_PER_MATCH=3            # max market tips por match tennis (top-K por EV)
# TENNIS_MARKET_SCAN_MIN_ODD=1.50          # MT scanner odd floor

# ─────────────────────────────────────────────────────────────────────────
# Tennis flags (consolidado)
# ─────────────────────────────────────────────────────────────────────────
# TENNIS_MIN_EDGE_TOP=2.5                  # Slam/Masters edge mínimo (pp)
# TENNIS_MIN_EDGE=4.0                      # demais torneios
# TENNIS_NON_SLAM_DISABLED=true            # bloqueia non-slam tier alto leak
# TENNIS_HANDICAP_GAMES_ENABLED=true       # default true; handicap games via Markov
# TENNIS_HANDICAP_SETS_LEGACY=false        # re-ativa path antigo (não recomendado)
# TENNIS_MARKOV_CALIB_DISABLED=false       # opt-out PAV+Beta calib (default ON)
# TENNIS_CORRELATION_ADJ=true              # discount Kelly quando ≥2 MT tips no match
# TENNIS_MT_TIER2_PROMOTE=true             # promove tier 2 (WTA125/Chall) — exceto ITF
# TENNIS_MIN_ODDS=1.40                     # gate odd mínima
# TENNIS_MAX_ODDS=5.00                     # gate odd máxima
# TENNIS_MARKET_SCAN_MAX_EV=40             # cap EV genérico tennis MT scanner
# TENNIS_MARKET_SCAN_MAX_EV_HANDICAPGAMES=55  # handicapGames ROI +10% prod 30d → relaxado
# TENNIS_MARKET_SCAN_MAX_EV_TOTALGAMES=40  # totalGames mantém conservador
# MT_PERMANENT_DISABLE_LIST=tennis|totalGames|over,lol|total   # leak prod 2026-04-30

# ─────────────────────────────────────────────────────────────────────────
# LoL flags
# ─────────────────────────────────────────────────────────────────────────
# LOL_BLOCK_SX_TIPS=true                   # default true; SX.Bet tem liquidez baixa em LEC = stale
# LOL_BLOCK_SX_TIPS_LIVE=true              # mesma regra para tips LIVE
# LOL_ISOTONIC_DISABLED=true               # default true (refit pioraria Brier)
# LOL_KILLS_PROMOTE=true                   # promove tips kills scanner
# LOL_KILLS_SCAN_MIN_EV=5                  # EV mínimo scanner kills
# LOL_KILLS_LEAGUE_BLEND=0.20              # blend λ_player x baseline da liga
# LOL_KILLS_BLUE_BOOST=0.5                 # +0.5 kills λ pra blue side (empírico)
# LOL_KILLS_MAP1_FACTOR=1.00               # ajustes per-mapa
# LOL_KILLS_MAP2_FACTOR=1.02
# LOL_KILLS_MAP3_FACTOR=0.97
# LOL_TIER2_EV_MIN=5                       # tier 2 EV (relaxado pós-retrain)

# ─────────────────────────────────────────────────────────────────────────
# Football MT (market tips)
# ─────────────────────────────────────────────────────────────────────────
# FOOTBALL_MT_SHADOW_ONLY=false            # promovido 2026-05-03 (ROI 40.9% / hit 71%); set true pra voltar shadow
# FOOTBALL_MT_MIN_EV=5                     # EV mínimo pré-jogo
# FOOTBALL_MT_LIVE_MIN_EV=8                # EV live (volatilidade maior)
# FOOTBALL_MT_MIN_PMODEL=0.50
# FOOTBALL_MT_MIN_ODD=1.50
# FOOTBALL_MT_MAX_ODD=3.50
# FOOTBALL_MT_PROMOTE_MIN_EV=8             # threshold promote
# FOOTBALL_MT_PROMOTE_MIN_PMODEL=0.55
# FOOTBALL_MARKET_TIP_MIN_EV=8
# FOOTBALL_MARKET_TIP_MIN_PMODEL=0.55
# FOOTBALL_MARKET_TIPS_ENABLED=false       # gate global; precisa ativar pra DM admin
# FB_MARKETS_TO_SHADOW=true                # 1X2_D/OVER/UNDER → market_tips_shadow

# ─────────────────────────────────────────────────────────────────────────
# Routing / tokens
# ─────────────────────────────────────────────────────────────────────────
# TIPS_UNIFIED_TOKEN=                      # consolida todos tips num bot único
# SYSTEM_ALERTS_TOKEN=                     # alerts/digests num bot separado
# AI_DISABLED=                             # true desativa /claude cross-sport (kill switch)
# REPORT_BUG_BENIGN_PATTERNS=              # csv regex extra pra silenciar erros benignos

# ─────────────────────────────────────────────────────────────────────────
# Funnel / shadow flags (focus 2026-04-24)
# ─────────────────────────────────────────────────────────────────────────
# FOOTBALL_SHADOW=true                     # tips→shadow não dispatch
# DOTA2_SHADOW=true
# VALORANT_SHADOW=true
# MMA_SHADOW=true
# DARTS_SHADOW=true
# SNOOKER_SHADOW=true
# TT_SHADOW=true                           # table tennis

# ─────────────────────────────────────────────────────────────────────────
# Kelly per-sport (KELLY_<SPORT>_<CONF> override KELLY_<CONF> → default)
# ─────────────────────────────────────────────────────────────────────────
# KELLY_LOL_ALTA=0.10
# KELLY_LOL_MEDIA=0.07
# KELLY_LOL_BAIXA=0.05
# KELLY_TENNIS_MEDIA=0.08
# KELLY_DOTA2_MEDIA=0.20                   # cut pós-CLV leak (era 0.70)

# ─────────────────────────────────────────────────────────────────────────
# Supabase BR odds aggregator
# ─────────────────────────────────────────────────────────────────────────
# SUPABASE_URL=                            # https://<project>.supabase.co
# SUPABASE_ANON_KEY=                       # anon key (read-only via RLS)

# ─────────────────────────────────────────────────────────────────────────
# Telegram tokens / cycles tuning
# ─────────────────────────────────────────────────────────────────────────
# MUTED_CYCLES=                            # csv de IDs de ciclos pra silenciar DM (debug)
# TIP_EV_MAX_PER_SPORT={"lol":12,"tennis":12,"cs2":15}   # JSON; defaults: lol/tennis 12, cs2 15, dota2/val/fb/mma/tt/darts/snk 25; fallback 35
# HIGH_EV_THROTTLE=true                    # default ON — fallback quando ev-calibration não tem amostra suficiente
# HIGH_EV_THROTTLE_THRESHOLD=8             # EV% acima do qual aplica corte
# HIGH_EV_THROTTLE_MULT=0.6                # multiplicador stake quando EV > threshold (0.6 = -40% stake)
# EV_CALIB=true                            # default ON — EV→ROI calibration data-driven (lib/ev-calibration); fallback p/ HIGH_EV_THROTTLE quando bucket sem amostra
# EV_CALIB_DAYS=60                         # janela amostra
# EV_CALIB_MIN_N=10                        # n mínimo por bucket (sport,EV) p/ usar mult calibrada
# EV_CALIB_MIN_MULT=0.20                   # floor multiplier (clamp inferior)
# EV_CALIB_SLOPE=1.6                       # shrink slope: ROI=-50% × 1.6 = -0.8 → mult=0.20
# EV_CALIB_REFRESH_MS=21600000             # 6h refresh interval
# SETTLEMENT_INTERVAL_MS=600000            # 10min default
# SOFASCORE_PROXY_BASE=                    # proxy URL pra evitar CF block (ou SOFASCORE_DIRECT=true)

# ─────────────────────────────────────────────────────────────────────────
# Sofascore direct (sem proxy)
# ─────────────────────────────────────────────────────────────────────────
# SOFASCORE_DIRECT=false                   # true acessa sofascore direto (CF pode bloquear)

# ─────────────────────────────────────────────────────────────────────────
# Audit leaks 2026-05-04 — ML real path sangrando
# ─────────────────────────────────────────────────────────────────────────
# Audit confirmou: LoL ML -28,9% n=24, CS ML -21,7% n=18 em 30d
# (-R$19,20 mensal = excede TODA perda da banca). MT path positivo no mesmo
# período. Gates abaixo restringem ML preservando MT.
# ─────────────────────────────────────────────────────────────────────────
LOL_ML_DISABLED=true                       # rejeita tips ML em LoL (mantém MT: kills, totals); auditável via /admin/sport-detail
CS_ML_DISABLED=true                        # rejeita tips ML em CS; cs2 MT (+12,6% n=51 CLV+12) é alternativa
TENNIS_ML_DISABLED=true                    # tennis path real ~99% MT (+9,4%); ML shadow -33,5% n=161 — formaliza skip
# Restrição alternativa (mais conservadora): permitir ML só em ligas tier 1.
# Substring match lowercase em event_name. NÃO use junto com _ML_DISABLED.
# LOL_ML_TIER1_LEAGUES=lck,lec,lpl,lcs,worlds,msi
# CS_ML_TIER1_LEAGUES=blast,iem,esl pro league,majors
FOOTBALL_ML_TIER1_LEAGUES=premier league,la liga,bundesliga,serie a,ligue 1,champions league,europa league,liga portugal,eredivisie
VALORANT_ML_TIER1_LEAGUES=vct,masters,champions,game changers

# ─────────────────────────────────────────────────────────────────────────
# MT scaling — recovery de leaks via per-market amplification
# ─────────────────────────────────────────────────────────────────────────
# CS2 MT total +15,7% n=40 hit 59% CLV+12 ⭐ — scale stake.
CS2_MT_TT_MIN_EV=5                         # default 8; captura edges 5-8% (n=51 valida)
CS2_TOTAL_STAKE_MULT=1.3                   # +30% stake em totals cs2; cap 2.0×
# Dota2 MT total +64,9% n=10 hit 71% CLV+10,63 ⭐ — small sample mas forte.
DOTA2_TOTAL_STAKE_MULT=1.2                 # +20% stake; conservador até n≥30
# LoL MT handicap +45,9% n=10 hit 86% — relax gate.
LOL_MT_HC_MIN_EV=6                         # default 8; captura handicap edges 6-8%
LOL_HANDICAP_STAKE_MULT=1.2                # +20% stake em handicap LoL
# Tennis HG +30,5% real (n=41) vs shadow -2,5% n=340 → tighten min_ev.
TENNIS_HG_MIN_EV=12                        # default 8; força edge >12% (filter agressivo)

# ─────────────────────────────────────────────────────────────────────────
# Self-healing + EV calib refit
# ─────────────────────────────────────────────────────────────────────────
AUTO_SHADOW_NEGATIVE_CLV=true              # flipa sport pra shadow auto quando CLV avg < -1% n≥30 (cron 6h)
TIME_OF_DAY_AUTO=true                      # bloqueia hora UTC com ROI persistentemente <-25% n≥8 (per-sport cache 1h)
EV_CALIB_DAYS=90                           # 60→90 (mais sample → menos ruído de bucket)
EV_CALIB_REFRESH_MS=10800000               # 3h vs 6h (react mais rápido a regime change)
FB_DIVERGENCE_MAX_PP=8                     # 12→8 (corta tips com modelo discrepante de Pinnacle close)

# ─────────────────────────────────────────────────────────────────────────
# Analytics Watchdog (DuckDB metrics auto-monitor)
# ─────────────────────────────────────────────────────────────────────────
# Cron 6h roda 12 métricas DAX, dispara DM admin quando thresholds breached.
# Throttle 24h por (rule, sport) via tabela analytics_alerts (mig 081).
ANALYTICS_WATCHDOG_AUTO=true                # default ON
ANALYTICS_WATCHDOG_INTERVAL_H=6             # horas entre checks
WATCHDOG_DAYS=30                            # janela default
WATCHDOG_COOLDOWN_HOURS=24                  # não realertar mesma rule+sport
# Thresholds (override defaults audit-driven):
# WATCHDOG_SHARPE_MIN=0                     # sharpe < X = alert
# WATCHDOG_DD_MAX_PCT=-25                   # max_dd_pct ≤ X = alert
# WATCHDOG_CALIB_MAX_GAP_PP=8               # |calib_gap| > X pp = alert
# WATCHDOG_TILT_LOSS_MIN=4                  # current loss streak ≥ X = alert
# WATCHDOG_CLV_MIN_PCT=-1                   # avg_clv < X% n≥30 = alert
# WATCHDOG_EV_LEAK_ROI=-15                  # bucket >12% ROI < X% = alert
# WATCHDOG_MATRIX_ROI_MIN=-25               # market×sport ROI < X% n≥15 = alert

# Daily digest (snapshot 1×/dia, hora UTC configurável).
ANALYTICS_DIGEST_AUTO=true                  # default ON
ANALYTICS_DIGEST_HOUR_UTC=12                # 12 UTC = ~9h BR
WATCHDOG_DIGEST_DAYS=7                      # janela mais curta = mais sensível
