# ── SportsEdge Bot — MMA Only (Fase 1) ──

# Telegram
TELEGRAM_TOKEN_MMA=           # Token do bot MMA via @BotFather
TELEGRAM_TOKEN_TENNIS=        # Token do bot Tênis via @BotFather

# APIs
CLAUDE_API_KEY=               # Anthropic Claude (claude-sonnet-4-6)
ODDS_API_KEY=                 # OddsPapi free tier — MMA odds (oddspapi.io, 250 req/mês)
THE_ODDS_API_KEY=             # The Odds API — futebol/tênis/mma (the-odds-api.com, 500 req/mês)
API_FOOTBALL_KEY=             # API-Football (api-sports.io) — fixtures sem odds, 100 req/dia grátis
API_FOOTBALL_DAILY_BUDGET=80  # Buffer de segurança (padrão 80 de 100)

# Cache HTTP (TTL por URL)
HTTP_CACHE_DEFAULT_TTL_MS=0              # 0=desligado (ainda faz dedupe in-flight)
HTTP_CACHE_MAX_ENTRIES=500               # limite entradas cache
HTTP_CACHE_MAX_BODY_BYTES=1048576        # 2026-05-21: cap body cacheado (default 1MB). Bodies maiores (Sofascore schedules 2-5MB) re-fetch ao invés de cachear. Prevenção heap pressure Railway 512MB.

# ─────────────────────────────────────────────────────────────────────────
# PnL Daily Report (lib/pnl-daily-message)
# ─────────────────────────────────────────────────────────────────────────
# PNL_DAILY_AUTO=true                    # default ON (cron 21h BRT dispara daily)
# PNL_DAILY_BR_HOUR=21                   # hora BRT do fire diário (default 21)
# PNL_DAILY_CUTOFF_DATE=2026-05-14       # 2026-05-21: ignora tips pré-reset. Vazio = sem cutoff. Aplicado a 30d, Total e janela 7d (defensivo). Tips REAIS apenas (is_shadow=0)
HTTP_CACHE_THEODDS_TTL_MS=14400000       # 4h padrão (The Odds API)
HTTP_CACHE_ODDSPAPI_TOURNAMENTS_TTL_MS=86400000  # 24h (lista tournaments)
HTTP_CACHE_ODDSPAPI_ODDS_TTL_MS=0        # odds OddsPapi (recomendado 0; backoff já controla)
HTTP_CACHE_ODDSPAPI_FIXTURE_TTL_MS=0     # odds-by-fixtures (handicap)

# Servidor
SERVER_PORT=3000
DB_PATH=/data/sportsedge.db  # Railway volume — use sportsedge.db localmente

# Model persistence (Railway Volume overlay) — sem env, no-op (dev/local intactos).
# Em prod: overlay arquivos *-isotonic/*-weights/*-calibration sobre lib/ no boot,
# sync de volta pós-fit em refresh-all-isotonics. Garante que nightly_retrain
# sobrevive deploy/restart. Volume deve estar montado (ex: /data).
MODEL_PERSISTENT_DIR=/data/models  # default unset = no-op

# Admin
ADMIN_KEY=                    # Header: x-admin-key ou Authorization: Bearer (protege rotas admin)
ADMIN_USER_IDS=               # ID numérico Telegram (obtenha via @userinfobot)

# Bucket gate (rejeita tips em faixas de odds com leak comprovado via roi-by-odds-bucket)
# Formato: "MIN-MAX" separado por vírgula. MIN inclusive, MAX exclusive.
# ODDS_BUCKET_BLOCK=2.20-3.00              # cross-sport (default vazio)
# VALORANT_ODDS_BUCKET_BLOCK=2.20-99       # per-sport override (additive ao global)
# LOL_ODDS_BUCKET_BLOCK=3.00-99
# CS_ODDS_BUCKET_BLOCK=
# TENNIS_ODDS_BUCKET_BLOCK=
# DOTA2_ODDS_BUCKET_BLOCK=
# MMA_ODDS_BUCKET_BLOCK=
# FOOTBALL_ODDS_BUCKET_BLOCK=

# Bucket auto-guard (cron 12h, persiste em DB table odds_bucket_blocklist)
# Auto-block (sport, bucket) quando n≥minN AND ROI≤cutoff AND CLV≤clvCutoff. Auto-restore se ROI recupera.
# ODDS_BUCKET_GUARD_AUTO=true              # default true; setar false desativa o cron
# ODDS_BUCKET_GUARD_MIN_N=30
# ODDS_BUCKET_GUARD_ROI_CUTOFF=-10
# ODDS_BUCKET_GUARD_CLV_CUTOFF=-2
# ODDS_BUCKET_GUARD_ROI_RESTORE=-2
# ODDS_BUCKET_GUARD_DAYS=30
# ODDS_MIN_TAKE_PCT=0.97                   # 2026-05-21: odd mínima aceitável em tip notification (0.97 = 3% pior que odd da tip). Mostrada no Telegram como "Odd mínima". Cross-sport ML + MT

# Pre-match EV bonus (audit-leaks 2026-04-22 mostrou PRE-match com ROI muito
# pior que LIVE em vários sports — odds estáticas viram fantasma quando mercado
# move antes do start). Bonus é aditivo ao EV mínimo já configurado per-sport.
# PRE_MATCH_EV_BONUS=                      # cross-sport (default 0)
# CS_PRE_MATCH_EV_BONUS=5                  # CS PRE -53% vs LIVE +19% (gap 72pp)
# VALORANT_PRE_MATCH_EV_BONUS=4            # Val PRE -44% vs LIVE +12% (gap 56pp)
# LOL_PRE_MATCH_EV_BONUS=4                 # esports PRE -37% vs LIVE +10% (gap 47pp)
# DARTS_PRE_MATCH_EV_BONUS=2               # Darts PRE +9% vs LIVE +49% (gap 40pp, marginal)
# DOTA2_PRE_MATCH_EV_BONUS=
# TENNIS_PRE_MATCH_EV_BONUS=               # tennis gap só 6pp, não justifica
# FOOTBALL_PRE_MATCH_EV_BONUS=

# Stake max cap (audit-leaks mostrou 3u tóxico em esports/cs/tennis — modelo
# overconfident em casos extremos). Clamp final aplicado em applyGlobalRisk.
# MAX_STAKE_UNITS=2.0                      # cross-sport cap (default sem cap em applyGlobalRisk)
#                                          # 2026-05-19 audit P0-3: também aplicado como
#                                          # HARD CLAMP em server.js /record-tip ANTES do
#                                          # portfolio adjust (default 15u). Bloqueia injeção
#                                          # de stake=50u via payload bypassando _applyKelly.
#                                          # Limite SAGRADO SOFT — só aumenta com audit explícito.
# CS_MAX_STAKE_UNITS=2.0                   # per-sport override
# ESPORTS_MAX_STAKE_UNITS=2.0              # equivalente a LOL no normSport
# LOL_MAX_STAKE_UNITS=2.0
# TENNIS_MAX_STAKE_UNITS=2.0
# DOTA2_MAX_STAKE_UNITS=
# VALORANT_MAX_STAKE_UNITS=

# Cap composto (2026-05-13): limita amplificação total dos multipliers em
# applyGlobalRisk (league × dd × perf × sport × dyn). Cap ratio adjusted /
# desiredUnits ≤ 1.5× — combinado com upstream (Kelly tier × trust × market ×
# tier2 ≤ 4.05×) dá total composed ≤ 6.07× (vs 13×+ sem cap).
# NÃO afeta cuts (drawdown taper × 0.35 continua reduzindo). Opt-out via 99.
# COMPOSED_MULT_CAP=1.5

# Daily tip limit — defesa contra concentração de risco em (sport, market).
# Hierarquia (most-specific wins): DAILY_TIP_LIMIT_<SPORT>_<MARKET> >
#   DAILY_TIP_LIMIT_<SPORT> > DAILY_TIP_LIMIT (global).
# Conta ML real (tips.is_shadow=0) + MT dispatched (market_tips_shadow.admin_dm_sent_at NOT NULL)
# que mapeiam pro mesmo market_type via MARKET_TYPE_MAP (HANDICAP_GAMES ML + handicapGames MT
# compartilham cap). Reset diário em BRT (DAILY_TZ_OFFSET_H=-3 default).
# Gates server-side em /record-tip (cobre ML + MT scanners).
# 2026-05-21 ex: tennis HANDICAP_GAMES emitiu 24 ML + 10 MT em 20/05 (sample).
# DAILY_TIP_LIMIT=8                          # global (per-sport fallback)
# DAILY_TIP_LIMIT_TENNIS=20                  # per-sport override
# DAILY_TIP_LIMIT_TENNIS_HANDICAP_GAMES=15   # (sport, market) granular cap
# DAILY_TIP_LIMIT_LOL_TOTAL=6                # ex: cap LoL totals MT

# MMA override: promove conf=MÉDIA quando IA off + sem trained model mas edge
# determinístico é robusto. Sem isso, override sempre BAIXA → gate BAIXA mata
# todas as tips MMA quando AI_DISABLED=true.
# MMA_OVERRIDE_PROMOTE_EDGE_PP=15          # edge mínimo (pp) pra promover BAIXA→MÉDIA
# MMA_OVERRIDE_PROMOTE_MIN_EV=10           # EV mínimo (%) pra promover

# Gates auto-tune (cron 12h, persiste em DB table gates_runtime_state)
# Auto-ajusta PRE_MATCH_EV_BONUS e MAX_STAKE_UNITS por sport baseado no que o
# audit-leaks mostraria — sem precisar setar envs manualmente. Env per-sport
# manual SEMPRE sobrepõe auto-tune (você mantém override preciso quando quiser).
# GATES_AUTOTUNE_AUTO=true                 # default true; setar false desativa
# GATES_AUTOTUNE_MIN_N=20                  # min sample por (sport, isLive) ou (sport, stakeBucket)
# GATES_AUTOTUNE_DAYS=30                   # janela de avaliação
# GATES_AUTOTUNE_PRE_GAP_PP=20             # gap LIVE-PRE (pp) que dispara +1 bonus
# GATES_AUTOTUNE_PRE_RELEASE_PP=5          # gap menor que isso → -1 bonus (libera)
# GATES_AUTOTUNE_STAKE_ROI_CUTOFF=-25      # bucket com ROI <= isso vira leak
# GATES_AUTOTUNE_MAX_BONUS=8               # cap absoluto pro bonus EV pre-match

# Feature flags (MMA only por defeito)
MMA_ENABLED=true
ESPORTS_ENABLED=false
TENNIS_ENABLED=false          # true para ativar o bot de tênis (requer TELEGRAM_TOKEN_TENNIS e THE_ODDS_API_KEY)
# TENNIS_MIN_ODDS=1.40        # Gate pós-IA: odd mínima (default 1.40, alinhado ao MMA)
# TENNIS_MAX_ODDS=5.00        # Gate pós-IA: odd máxima (default 5.00)
# TENNIS_ISOTONIC_DISABLED=true  # Kill-switch: bypassa lib/tennis-model-isotonic.json
                                 # (overshooting na zona [0.40, 0.55) — ROI -64% bucket 2.20-3.00)
                                 # Não afeta isotonic interno do trained model (tennis-weights.json)

# Meta LoL
LOL_PATCH_META=                  # Ex: "Patch 15.6 — Azir/Corki meta mid, Garen top forte"
PATCH_META_DATE=                 # Ex: 2025-03-19 — auto-atualizado pelo bot via ddragon

# Calibração de thresholds (opcional — ajuste para mais ou menos tips)
# LOL_PREGAME_BLOCK_BO3=true     # true=só analisa Bo1 pré-jogo (maior qualidade) | false=analisa todos pré-jogo
# LOL_EV_THRESHOLD=1.5           # EV mínimo para emitir tip (%) — padrão 1.5, use 1.0 para mais tips
# LOL_PINNACLE_MARGIN=2.5        # Margem mínima vs Pinnacle (pp) — padrão 2.5, use 2.0 para mais tips
# LOL_NO_ODDS_CONVICTION=60      # Convicção mínima sem odds (%) — padrão 60, use 55 para mais tips

# ─────────────────────────────────────────────────────────────────────────
# Football data CSV (football-data.co.uk integration — sem auth)
# ─────────────────────────────────────────────────────────────────────────
# FB_USE_FD_CSV=true                       # default true; false desativa fd_features no Poisson
# FB_DIVERGENCE_GATE=true                  # bloqueia tips 1X2 com divergência grande vs Pinn closing
# FB_DIVERGENCE_MAX_PP=12                  # threshold (default 12pp); >max → skip dispatch
# XG_PER_SOT=0.32                          # conversion factor shots-on-target → xG (lit avg 0.30-0.34)

# ─────────────────────────────────────────────────────────────────────────
# Memory / TTL (anti-leak Maps in-memory)
# ─────────────────────────────────────────────────────────────────────────
# ANALYZED_TTL_MS=259200000                # 72h default; sweep cron 1h remove entries antigas
# MARKET_TIP_SENT_TTL_MS=172800000         # 48h default; dedup MT tips

# ─────────────────────────────────────────────────────────────────────────
# DB Backup (VACUUM INTO snapshot diário)
# ─────────────────────────────────────────────────────────────────────────
# DB_BACKUP_AUTO=true                      # default true; cron 30min checa hora
# DB_BACKUP_HOUR_UTC=4                     # 4h UTC = 1h BRT (madrugada baixa atividade)
# DB_BACKUP_KEEP_DAYS=7                    # retention; deleta backups/sportsedge_*.db mais velhos
# DB_SYNCHRONOUS=NORMAL                    # NORMAL (default WAL+NORMAL) | FULL (durabilidade absoluta)
# DB_SLOW_QUERY_MS=0                       # 0 = off; >0 ativa wrap em prepare() pra log queries lentas
# DAILY_LEAKS_DIGEST_AUTO=true             # cron 1x/dia DM admin com top leaks (n>=20, ROI<=-15%)
# DAILY_LEAKS_DIGEST_HOUR_UTC=13           # 13h UTC = 10h BRT
# DAILY_LEAKS_MIN_N=20
# DAILY_LEAKS_ROI_CUTOFF=-15
# DAILY_LEAKS_DAYS=7
# MT_RESTORE_AUTO=true                     # cron diário sugere remover bloqueados que recuperaram
# MT_RESTORE_HOUR_UTC=14                   # 14h UTC = 11h BRT (1h pós leaks digest)
# MT_RESTORE_MIN_N=30
# MT_RESTORE_DAYS=14
# MT_RESTORE_MIN_ROI=0                     # ROI%
# MT_RESTORE_MIN_CLV=0                     # CLV%
# WEEKLY_DIGEST_AUTO=true                  # default ON; weekly summary 1x/semana DM admin
# WEEKLY_DIGEST_DAY_UTC=1                  # 1=Mon (0=Sun)
# WEEKLY_DIGEST_HOUR_UTC=14                # 14h UTC = 11h BRT
# WEEKLY_DIGEST_DAYS=7                     # janela de stats
# MEM_WATCHDOG_DISABLED=                   # true desativa watchdog
# MEM_WATCHDOG_AUTO=true                   # P95 baseline 7d × 1.3 (default ON)
# MEM_WATCHDOG_AUTO_MARGIN=1.3             # margem multiplicativa sobre P95
# MEM_WATCHDOG_RSS_MB=                     # override hard (sobrepõe auto-tune)
# CRON_MEM_HEAP_DELTA_LOG_MB=40            # log [CRON-MEM] quando ΔheapUsed >= MB (atribui spike a cron)
# CRON_MEM_RSS_DELTA_LOG_MB=60             # log [CRON-MEM] quando Δrss >= MB

# Esports MT calib refit (daily 05h local, multi-sport)
# Schema v2.1 side-aware. Causa-fix LoL total EV>30% leak (gap+124pp).
# ESPORTS_CALIB_REFIT_DISABLED=false       # default ON
# ESPORTS_CALIB_REFIT_SPORTS=lol,cs2,dota2,valorant  # filter sports
# <SPORT>_MT_CALIB_DISABLED=true           # disable calib loader per sport (LOL_MT_CALIB_DISABLED, etc)
# <SPORT>_MT_CALIB_PATH=                    # override file path (default lib/<sport>-mt-calib.json)

# Cap EV-cirúrgico per (sport, market) — corta tips em buckets EV alto onde
# gap calib é estrutural. Caso 2026-05-12: LoL total EV>30% gap+124pp ROI-60%.
# Hierarquia: MT_EV_CAP_<SPORT>_<MARKET> > MT_EV_CAP_<SPORT> > MT_EV_CAP_PCT > 50
# MT_EV_CAP_LOL_TOTAL=25                   # rec pós-audit 2026-05-12 (LoL total)
# MT_EV_CAP_CS_TOTAL=20                    # rec pós-audit 2026-05-12 (CS total under)

# News-impact gate em /record-tip (fecha gap "news só DM, não bloqueia tip ruim")
# News monitor cron 15min popula lib/news-impact cache com {team_norm, severity, ttl 3h}.
# /record-tip consulta antes de gravar:
#   critical (cancelled/withdrawal/DQ/ban) → skip hard
#   warning  (injury/sub/roster change)    → log + flag forensics
# Bypass shadow (is_shadow=1) e pode desativar manualmente:
# NEWS_IMPACT_GATE_DISABLED=false          # default OFF (gate ATIVO)
# Endpoint /admin/news-impact mostra entries ativas (debug)

# Steam BOOST — velocity favorável boosta stake (sharp money confirma side)
# Espelha CLV pre-dispatch gate (que JÁ BLOQUEIA quando sharp vai contra).
# Quando Pinnacle odd CAIU >=STEAM_BOOST_THRESHOLD_PCT no nosso side em
# STEAM_BOOST_WINDOW_MIN minutos → kellyFraction *= STEAM_BOOST_MULT
# STEAM_BOOST_DISABLED=false               # default ON
# STEAM_BOOST_THRESHOLD_PCT=3              # mínimo movimento pra trigger (default 3%)
# STEAM_BOOST_WINDOW_MIN=10                # janela velocity (default 10min)
# STEAM_BOOST_MULT=1.20                    # mult inicial (default 1.20)
# STEAM_BOOST_MAX_MULT=1.50                # cap absoluto (default 1.50)

# Portfolio Kelly — correlation-aware stake discount cross-cycle
# Quando há tips abertas correlatas (mesma série Bo3 LoL ou mesmo sport recent),
# reduz stake da nova tip pra evitar over-exposure. Usa esports-correlation /
# tennis-correlation libs existentes pra estimar corr.
# Aplicado em server.js /record-tip antes de gravar.
# PORTFOLIO_KELLY_DISABLED=false           # default ON
# PORTFOLIO_KELLY_CAP_UNITS=10             # cap total exposure por sport (units)
# PORTFOLIO_KELLY_CAP_LOL_UNITS=8          # override per sport
# PORTFOLIO_KELLY_CORR_THRESHOLD=0.3       # corr mínima pra trigger discount
# PORTFOLIO_KELLY_DISCOUNT_FACTOR=0.5      # discount = maxCorr × factor (cap 0.5)
# Endpoint /admin/portfolio-kelly?sport=X&team1=A&team2=B&stake=1.5 → dry-run

# CS live pricing — dist condicional ao score atual (lib/cs-live-pricing)
# Quando isLiveCs e score parcial (score1+score2 > 0), MT scanner usa pricing
# live que recalcula P(handicap/total) dado placar. Pre-game cai em lol-markets.
# Sem env opt-out — comportamento determinístico (pre-game match.score=0 mantém legacy).
# Endpoint /admin/live-tips-debug?sport=cs reflete impacto pós-deploy.
# SAME_PICK_ONLY_DEDUP_SPORTS=             # csv sports onde dedup só bloqueia mesmo pick (raro: arb/parlay)

# ─────────────────────────────────────────────────────────────────────────
# Autonomy / loops defensivos (default ON; opt-out =false)
# ─────────────────────────────────────────────────────────────────────────
# AUTONOMY_DIGEST_AUTO=true                # daily digest 1x/dia DM admins
# AUTONOMY_DIGEST_HOUR_UTC=12              # 12h UTC = 9h BRT
# NIGHTLY_RETRAIN_AUTO=true                # refresh-all-isotonics.js diário
# NIGHTLY_RETRAIN_HOUR_UTC=3               # 3h UTC = 0h BRT
# AUTO_ROLLBACK_ON_REGRESSION=true         # rollback modelo se Brier piora pós-retrain (weights) OR nCalib drop >50% (isotonics/Markov calib)
# REGRESSION_THRESHOLD_PCT=5                # weights brier worse-pct threshold (default 5%)
# ISOTONIC_SAMPLE_DROP_THRESHOLD_PCT=50     # isotonic/Markov calib nCalibSamples drop threshold (default 50%)
# BRIER_AUTO_EV_CAP=true                   # reduz EV ceiling quando Brier degrada
# LIVE_RISK_MONITOR_AUTO=true              # auto-void tips live com risco extremo
# AUTO_VOID_STUCK_AUTO=true                # auto-void tips pendentes >48h
# SHADOW_VOID_DAYS=14                       # void tips shadow após X dias (default 14, vs 36h real).
                                            # Necessário pra matches fantasma (Pinnacle expôs odds
                                            # preliminares antes do bracket draw, depois removeu).
                                            # Override per-sport: SHADOW_VOID_DAYS_TENNIS=20 etc.
# REANAL_VOID_INCLUDE_SHADOW=false          # P2 defensive (2026-05-15): default false skipa shadow tips
                                            # em reanalyzeAndVoidFailing (/admin/reanalyze-void).
                                            # Shadow é research universe — voidar quando EV atual cai
                                            # destrói dataset puro pré-fight. Setar true preserva legacy.
# MT_LEAK_GUARD_AUTO=true                  # auto-disable (sport,market) com CLV leak
# MT_LEAK_EARLY_AUTO=true                  # Bayesian early-warning (ROI extremo + n baixo)
# MT_LEAK_EARLY_ROI_STEPS=[{"n":4,"roi":-70},{"n":6,"roi":-50},{"n":8,"roi":-35}]
# MT_LEAK_EARLY_MIN_N=4                    # floor minN pra sport+market overall
# MT_LEAK_EARLY_MIN_N_SIDE=6               # floor minN pra sport+side OU sport+tier
# MT_LEAK_EARLY_MIN_N_LEAGUE=8             # floor minN pra sport+side+league (granular narrow)

# ─────────────────────────────────────────────────────────────────────────
# CLV pre-dispatch gate (sharp money entrou no lado oposto = stale)
# ─────────────────────────────────────────────────────────────────────────
# CLV_PREDISPATCH_GATE=true                # default true; gate antes do dispatch
# CLV_PREDISPATCH_THRESHOLD=2.5            # %, odd subiu >X% nos últimos N min = skip
# CLV_PREDISPATCH_WINDOW_MIN=10            # janela de medida (min)
# VELOCITY_WINDOW_MIN=10                   # cross-uso por velocity-tracker

# ─────────────────────────────────────────────────────────────────────────
# Tournament / dedup caps
# ─────────────────────────────────────────────────────────────────────────
# MAX_TIPS_PER_TOURNAMENT_PER_DAY=8        # limite tips por liga/dia (anti-concentração)
# TENNIS_MARKET_MAX_PER_MATCH=3            # max market tips por match tennis (top-K por EV)
# TENNIS_MARKET_SCAN_MIN_ODD=1.50          # MT scanner odd floor
# TENNIS_EXTREME_LINE_GUARD_DISABLED=false # 2026-05-19: scanner-level cap EV em 30%
#                                          # quando line é extrema (handicapGames |line|>5.5 OU
#                                          # totalGames |line-22.5|>6.5). Markov calib v2 sparse
#                                          # em line magnitudes — heurística evita EVs absurdos
#                                          # (482%, 209%) no shadow path. Default OFF (=guard ativo).
# TENNIS_EXTREME_LINE_EV_CAP_PCT=30        # cap usado pelo extreme-line guard acima

# ─────────────────────────────────────────────────────────────────────────
# Tennis flags (consolidado)
# ─────────────────────────────────────────────────────────────────────────
# TENNIS_MIN_EDGE_TOP=2.5                  # Slam/Masters edge mínimo (pp)
# TENNIS_MIN_EDGE=4.0                      # demais torneios

# ─────────────────────────────────────────────────────────────────────────
# Per-sport ML edge minimum override (shadow research expansion, 2026-05-13)
# ─────────────────────────────────────────────────────────────────────────
# Quando setado, substitui thresholds default (3pp comp / 4pp no-comp) em
# lib/ml.js esportsPreFilter. Reduz threshold → mais tips passam prefilter
# → mais volume shadow research universe (P2 compliant).
# Atenção: tips que passam ML prefilter podem virar REAL se passarem todos
# gates downstream (EV ceiling, conf, divergence). Threshold baixo = mais real
# volume também. Use com cuidado em sports já com volume real ok (LoL/CS).
#
# Tennis: env funciona apenas no fallback path (linha 18115); path principal
# usa TENNIS_MIN_EDGE_TOP/TENNIS_MIN_EDGE acima (já configuráveis).
# LOL_ML_EDGE_MIN=1
# DOTA2_ML_EDGE_MIN=0.5
# CS_ML_EDGE_MIN=2
# MMA_ML_EDGE_MIN=2
# TABLETENNIS_ML_EDGE_MIN=1
# VALORANT_ML_EDGE_MIN=2
# VALORANT_FORM_WINDOW=10                  # window getRecentForm em getValorantModel; default 10. Widen p/ teams regionais (Spain/Challengers) — validar shadow 14d antes
# TENNIS_ML_EDGE_MIN=-0.5                  # fallback path apenas
# TENNIS_NON_SLAM_DISABLED=true            # bloqueia non-slam tier alto leak
# TENNIS_HANDICAP_GAMES_ENABLED=true       # default true; handicap games via Markov
# TENNIS_HANDICAP_SETS_LEGACY=false        # re-ativa path antigo (não recomendado)
# TENNIS_MARKOV_CALIB_DISABLED=false       # opt-out PAV+Beta calib (default ON)
# TENNIS_CALIB_FORMAT_DISABLED=false       # opt-out v3 tier+format split (Bo3/Bo5), cai pra v2.1 tier-only
# LOL_AI_SHADOW=true                       # AI shadow POC dispatch (DeepSeek) — research A/B
# LOL_AI_REAL=true                         # 2026-05-18: promove AI path pra real tips + DM dispatch.
# LOL_ML_PER_MAP=true                      # 2026-05-20 Sprint 1: emit market_type='MAP{N}_WINNER' em vez de
#                                          # 'ML' quando live + liveMapa. Usa modelP1/P2 de lol-map-model.js
#                                          # (gold/towers/drakes/barons/momentum). Default OFF.
# LOL_ML_PER_MAP_SHADOW=true               # 2026-05-20 Sprint 1: shadow gate per-map (default true=shadow).
#                                          # Setar 'false' promove real APÓS Sprint 2 settle + n>=30 shadow.
# CS_ML_PER_MAP=true                       # 2026-05-20 Sprint 5: emit CS market_type='MAP{N}_WINNER' live.
#                                          # Settle via HLTV match page parser (Sprint 4). Default OFF.
# CS_ML_PER_MAP_SHADOW=true                # Shadow gate CS per-map (default true).
# DOTA2_ML_PER_MAP=true                    # 2026-05-20 Sprint 5: emit Dota2 market_type='MAP{N}_WINNER' live.
#                                          # Settle via /dota-result _MAP{N} (PS games array, pre-existing).
#                                          # Default OFF.
# DOTA2_ML_PER_MAP_SHADOW=true             # Shadow gate Dota2 per-map (default true).
# VALORANT_ML_PER_MAP=true                 # 2026-05-20 Sprint 6: emit Val market_type='MAP{N}_WINNER' live.
#                                          # Settle via VLR.gg scraper (lib/vlr.js getValorantMatchMapResults).
#                                          # Default OFF.
# VALORANT_ML_PER_MAP_SHADOW=true          # Shadow gate Val per-map (default true).
# MMA_AI_SHADOW=true                       # 2026-05-18: A/B mirror MMA shadow POC.
#                                          # MMA main path já usa AI; shadow compara "AI puro" vs
