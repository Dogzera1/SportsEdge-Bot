# Economy gates AI shadow (per-sport tuning):
# <SPORT>_AI_COOLDOWN_H=4                  # Per-match cooldown (default 4h). =0 desativa.
#                                          # Evita re-análise mesmo match em ciclos consecutivos (poll 5min).
# <SPORT>_AI_MIN_EDGE=3                    # Pre-filter edge mínimo (default 3pp). =0 desativa.
#                                          # Skip /claude call se modelo não tem signal — economiza DeepSeek $$.
# <SPORT>_AI_DAILY_CAP=15                  # Cap calls/dia per sport SHADOW path (default 15 desde 2026-05-19).
#                                          # =0 unlimited. Atenção: counter só conta shadow, NÃO inclui main /claude calls
#                                          # (Dota/CS/Tennis/Football/MMA já chamam /claude no main path). Defesa global
#                                          # em AI_MONTHLY_BUDGET_USD abaixo.
# <SPORT>_AI_TIER1_ONLY=true               # 2026-05-21: bloqueia AI emit em tier não-1 (tier2/tier3/unknown).
#                                          # Audit ROI: LOL AI DeepSeek 4/4 losses 7d em tier3 minor leagues
#                                          # (NACL Winthrop, LCK CL Kiwoom DRX, La Ligue Galions). Modelo overcalla
#                                          # edge em leagues raras onde sample histórico é insuficiente. Default OFF
#                                          # (opt-in per sport). Helper _leagueTier (memory commit 7f9dcc9 unificado):
#                                          #   tier1 = major (LCK/LEC/LPL/LCS, WTA Slam/Masters, NBA, UFC)
#                                          #   tier2 = regional (CBLOL/LJL/PCS, WTA 250/500, Euroleague, Bellator)
#                                          #   tier3 = minor/Academy/Challenger (NACL/LCK CL/Galions, ITF/Challenger)
#                                          # Recomendado: LOL_AI_TIER1_ONLY=true (até refit calib AI tier-aware).
#                                          # Metric: ai_shadow_skip_tier{sport,tier} via /admin/metrics.
# AI_MONTHLY_BUDGET_USD=10                 # 2026-05-19: hard cap mensal cross-sport ($USD).
#                                          # Server.js /claude proxy lê api_usage deepseek tokens, computa custo via
#                                          # pricing oficial ($0.14/M input + $0.28/M output) e bloqueia /claude quando
#                                          # custo >= cap. Bloqueio retorna content vazio → callers tratam como SEM_EDGE
#                                          # (fail-soft). Reseta automaticamente no virar do mês. =0 desativa (custo ilimitado).
#                                          # Fallback estimate $0.000168/call quando DeepSeek não retorna usage.
#                                          # Default false (path shadow). A/B 14d revelou AI ROI +15.65%
#                                          # n=61 vs no-AI -7.89% n=28 (memory project_lol_ai_vs_noai_comparison).
#                                          # Quando true: AI tip isShadow=0, emission_source=lol_ai_real,
#                                          # DM via TELEGRAM_TOKEN_ESPORTS pra subscribed users.
