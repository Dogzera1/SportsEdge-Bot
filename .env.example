# ─────────────────────────────────────────────────────────────────────────
# Kelly per-sport (KELLY_<SPORT>_<CONF> override KELLY_<CONF> → default)
# ─────────────────────────────────────────────────────────────────────────
# Defaults globais: ALTA=0.25 (¼ Kelly, maxStake=4u), MEDIA=0.167 (⅙ Kelly,
# maxStake=3u), BAIXA=0.10 (1/10 Kelly, maxStake=1.5u). Cascade resolve:
#   KELLY_<SPORT>_<MARKET>_<CONF> > KELLY_<SPORT>_<CONF> > KELLY_<CONF> > default
#
# 2026-05-21 audit: user reportou LoL ALTA 3-4u "muita coisa" + CS resultados
# ruins recentes. Recomendação conservadora (reversível via env Railway):
#   LoL ALTA 0.25→0.20 (~3.2u vs ~4u, -20%)
#   CS  ALTA 0.25→0.18 (~2.9u vs ~4u, -28%); MEDIA 0.167→0.13; BAIXA 0.10→0.07
# Mantém tier mult (lol tier1=1.30×, cs tier1=1.20×) e product cap 0.15.
# KELLY_LOL_ALTA=0.20
# KELLY_LOL_MEDIA=0.13                     # opcional — só ajustar se MEDIA também excessiva
# KELLY_LOL_BAIXA=0.07
# KELLY_CS_ALTA=0.18
# KELLY_CS_MEDIA=0.13
# KELLY_CS_BAIXA=0.07
# KELLY_TENNIS_MEDIA=0.08
# KELLY_DOTA2_MEDIA=0.20                   # cut pós-CLV leak (era 0.70)
#
# Kelly product cap observability (commit dbaa9b1 audit 2026-05-21):
# KELLY_PRODUCT_CAP_FRAC=0.15              # cap composição multiplier (SAGRADO default 0.15)
#                                          # Aplica em _applyKelly (lib/utils.js:340) E kellyStakeForMarket
#                                          # (lib/market-tip-processor.js:189). Setar 0 desativa cap.
# KELLY_CAP_ALERT_THRESHOLD_PER_HOUR=5     # alert autonomy_digest quando cap dispara >N/h (default 5).
#                                          # Cap é safety net — firing >threshold = composição estrutural
#                                          # excessiva (verificar tier×market×trust×clv stack).

# ─────────────────────────────────────────────────────────────────────────
# Supabase BR odds aggregator
# ─────────────────────────────────────────────────────────────────────────
# SUPABASE_URL=                            # https://<project>.supabase.co
# SUPABASE_ANON_KEY=                       # anon key (read-only via RLS)

# ─────────────────────────────────────────────────────────────────────────
# Telegram tokens / cycles tuning
# ─────────────────────────────────────────────────────────────────────────
# ─────────────────────────────────────────────────────────────────────────
# Security hardening (audit 2026-05-19)
# ─────────────────────────────────────────────────────────────────────────
# RECORD_TIP_TOKEN_REQUIRED=true            # P0-1: força x-record-tip-token header em /record-tip.
#                                            # SET TRUE EM PROD após confirmar RECORD_TIP_TOKEN setado
#                                            # em bot+server services (bot inclui auto via env).
# RECORD_TIP_TOKEN=<32-byte-hex>             # token compartilhado bot↔server (gerar via openssl rand -hex 32)
# RECORD_TIP_MAX_BODY_BYTES=65536           # P0-2: cap body POST /record-tip (default 64KB).
#                                            # Tip JSON real ~2-4KB; cap previne OOM Railway 512MB via
#                                            # body unbounded (atacante POST 500MB → V8 alloc → SIGKILL).
# PINNACLE_ODDS_UPPER_BOUND=50              # P0-5: upper bound em impliedProbsFromOdds.
#                                            # Pinnacle ML real raramente >30; >50 = parser bug / feed
#                                            # poisoning / MITM. Sem cap, bot calcula EV bizarro.
#                                            # Disable com =0 (não recomendado).
# POST_MAX_BODY_BYTES=65536                 # P0-2 propagated: cap body em endpoints POST críticos
#                                            # (/set-bankroll, /reset-tips, /void-old-pending, /settle-manual).
#                                            # /record-tip usa env separado RECORD_TIP_MAX_BODY_BYTES.
#                                            # Default 64KB cobre payloads reais com margem 16×.
# BROWSER_UA=<custom UA>                    # 2026-05-19 P3: override User-Agent string usada por
#                                            # 11 libs (sofascore/hltv/vlr/pinnacle/etc). Default
#                                            # Chrome/131 em Windows. Mude pra rotacionar UA quando
#                                            # provider rotaciona WAF — 1 env change ao invés de 11 edits.

# MUTED_CYCLES=                            # csv de IDs de ciclos pra silenciar DM (debug)
# TIP_EV_MAX_PER_SPORT={"lol":12,"tennis":12,"cs2":15}   # JSON; defaults: lol/tennis 12, cs2 15, dota2/val/fb/mma/tt/darts/snk 25; fallback 35
# HIGH_EV_THROTTLE=true                    # default ON — fallback quando ev-calibration não tem amostra suficiente
# HIGH_EV_THROTTLE_THRESHOLD=8             # EV% acima do qual aplica corte
# HIGH_EV_THROTTLE_MULT=0.6                # multiplicador stake quando EV > threshold (0.6 = -40% stake)
# HIGH_EV_THROTTLE_DISABLED_SPORTS=basket,mma,tt  # 2026-05-21 per-sport opt-out (csv lowercase). Audit recomendado quando calib não pronta (sample baixo) — throttle blanket 0.6 corta edge mesmo em buckets bem calibrados
# EV_CALIB=true                            # default ON — EV→ROI calibration data-driven (lib/ev-calibration); fallback p/ HIGH_EV_THROTTLE quando bucket sem amostra
# EV_CALIB_DAYS=60                         # janela amostra
# EV_CALIB_MIN_N=10                        # n mínimo por bucket (sport,EV) p/ usar mult calibrada
# EV_CALIB_MIN_MULT=0.20                   # floor multiplier (clamp inferior)
# EV_CALIB_SLOPE=1.6                       # shrink slope: ROI=-50% × 1.6 = -0.8 → mult=0.20
# EV_CALIB_REFRESH_MS=21600000             # 6h refresh interval
# EV_CALIB_REAL_ONLY=true                  # 2026-05-07 P2 fix: shadow não contamina mult; default ON
# ── 2026-05-21: Boost mode opt-in (cap 1.0 → até 1.5 quando ROI+IC strong) ──
# EV_CALIB_BOOST=false                     # default OFF. true → mult > 1.0 quando ROI ≥ boostStart AND n ≥ icMinN
# EV_CALIB_BOOST_CAP=1.5                   # cap superior do mult quando boost ativo (1.5 = +50% stake máximo)
# EV_CALIB_BOOST_MIN_N=30                  # IC strong guardrail: n mínimo por bucket pra ativar boost (evita noise em sample <30)
# EV_CALIB_BOOST_START=0.05                # ROI mínimo pra começar boost (ROI<5% → mult=1.0)
# EV_CALIB_BOOST_SLOPE=2.0                 # slope linear: ROI 0.05+x × 2.0 → mult 1+2x; ex: ROI 15% → 1.20; ROI 25% → 1.40
# LEAGUE_TRUST_REAL_ONLY=true              # 2026-05-07 P2 fix: trust ratio só vê tips real (is_shadow=0); default ON
# MT_AUTO_PROMOTE_REAL_ONLY=true           # 2026-05-07 P2 fix: REVERT/LEAGUE_BLOCK usam tips real; PROMOTE continua shadow (pre-promote eval)

# ─────────────────────────────────────────────────────────────────────────
# Frozen holdout (RECOMENDADO PROD — proteção contra overfitting auto-tune)
# ─────────────────────────────────────────────────────────────────────────
# Auto-tunes (kelly, mt_auto_promote, gates_autotune, ev_calibration, learned_corrections,
# readiness_learner, leak/bucket guards) treinam em janela rolling 30-90d. Sem holdout
# eles tomam decisões usando dados que vão re-avaliar nos mesmos sistemas — overfitting
# estrutural (decisão "boa em sample" pode ser pior em out-of-sample).
#
# FROZEN_HOLDOUT_DAYS=60 reserva últimos 60d intactos pra eval manual via /admin/holdout-status.
# Auto-tune passa a treinar em [-(window+60), -60d]. Reduz reativiidade (tunes demoram 60d
# pra incorporar regime change novo) — tradeoff aceito pra evitar churn em ruído.
# Override per-sistema: FROZEN_HOLDOUT_KELLY_DAYS=120 (mais conservador), etc.
# FROZEN_HOLDOUT_DAYS=60                   # default 0 (OFF). RECOMENDADO setar 60-90 em prod.

# ─────────────────────────────────────────────────────────────────────────
# Shadow vs Real drift detector (early warning model decay)
# ─────────────────────────────────────────────────────────────────────────
# Detecta quando shadow ROI degrada (modelo puro sangrando) enquanto real ROI
# fica estável (gates mascarando). P2-compliant: só DM admin, sem auto-action.
# SHADOW_VS_REAL_DRIFT_AUTO=true            # default true. =false desativa cron.
# SHADOW_VS_REAL_DRIFT_WINDOW_DAYS=14       # janela "recente"; baseline = window..2*window
# SHADOW_VS_REAL_DRIFT_GAP_PP=5             # gap (delta_shadow - delta_real) que dispara alert
# SHADOW_VS_REAL_DRIFT_SHADOW_DROP_PP=3     # delta_shadow precisa cair ≥ isso
# SHADOW_VS_REAL_DRIFT_MIN_N_SHADOW=30      # amostra mínima per janela shadow
# SHADOW_VS_REAL_DRIFT_MIN_N_REAL=20        # amostra mínima per janela real

# ─────────────────────────────────────────────────────────────────────────
# Gate attribution weekly — counterfactual analysis dos gates atuais
# ─────────────────────────────────────────────────────────────────────────
# Aplica gates atuais retroativamente em tips reais settled e mede saved_loss vs
# lost_profit per gate. Detecta gate que corta wins mais do que losses (cortando edge).
# DM admin segunda 15h UTC (12h BRT) com top 5 gates por |net|.
# GATE_ATTRIBUTION_AUTO=true                # default true. =false desativa cron.
# GATE_ATTRIBUTION_DAYS=30                  # janela settled
# GATE_ATTRIBUTION_DOW=1                    # 0=Sun, 1=Mon, etc
# GATE_ATTRIBUTION_HOUR_UTC=15              # 15h UTC = 12h BRT
# GATE_ATTRIBUTION_MIN_N_PER_GATE=5         # n mínimo per gate pra reportar

# ─────────────────────────────────────────────────────────────────────────
# P2 Compliance Weekly Auto-Check — DM admin se config drift
# ─────────────────────────────────────────────────────────────────────────
# Detecta drift de config (alguém setou EV_CALIB_REAL_ONLY=false sem querer,
# FROZEN_HOLDOUT_DAYS removido em deploy). Roda toda segunda 14h UTC.
# P2_COMPLIANCE_AUTO=true                   # default true. =false desativa cron.
# P2_COMPLIANCE_DOW=1                       # 1=Monday
# P2_COMPLIANCE_HOUR_UTC=14                 # 14h UTC = 11h BRT
# SETTLEMENT_INTERVAL_MS=600000            # 10min default
# SOFASCORE_PROXY_BASE=                    # proxy URL pra evitar CF block (ou SOFASCORE_DIRECT=true)

# ─────────────────────────────────────────────────────────────────────────
# Sofascore direct (sem proxy)
# ─────────────────────────────────────────────────────────────────────────
# SOFASCORE_DIRECT=false                   # true acessa sofascore direto (CF pode bloquear)

# ─────────────────────────────────────────────────────────────────────────
# Audit leaks 2026-05-04 — ML real path sangrando
# ─────────────────────────────────────────────────────────────────────────
# Audit confirmou: LoL ML -28,9% n=24, CS ML -21,7% n=18 em 30d
# (-R$19,20 mensal = excede TODA perda da banca). MT path positivo no mesmo
# período. Gates abaixo restringem ML preservando MT.
# ─────────────────────────────────────────────────────────────────────────
LOL_ML_DISABLED=true                       # rejeita tips ML em LoL (mantém MT: kills, totals); auditável via /admin/sport-detail
CS_ML_DISABLED=true                        # rejeita tips ML em CS; cs2 MT (+12,6% n=51 CLV+12) é alternativa
TENNIS_ML_DISABLED=true                    # tennis path real ~99% MT (+9,4%); ML shadow -33,5% n=161 — formaliza skip
# 2026-05-27: WTA ML promote filter (audit shadow 28d n=465 WTA: EV 20-30% cross-
# tournament ROI +26% n=126; QUALI ROI -14% n=180; ATP overall -6%). Promote opt-in.
# TENNIS_ML_PROMOTE_FILTER=false           # true → emite real apenas WTA MAIN + EV ∈ [min,max]
# TENNIS_ML_PROMOTE_EV_MIN=20              # EV mínimo (%) para promover
# TENNIS_ML_PROMOTE_EV_MAX=30              # EV máximo (%) — >30 sangra cross-tournament
# Restrição alternativa (mais conservadora): permitir ML só em ligas tier 1.
# Substring match lowercase em event_name. NÃO use junto com _ML_DISABLED.
# LOL_ML_TIER1_LEAGUES=lck,lec,lpl,lcs,worlds,msi
# CS_ML_TIER1_LEAGUES=blast,iem,esl pro league,majors
FOOTBALL_ML_TIER1_LEAGUES=premier league,la liga,bundesliga,serie a,ligue 1,champions league,europa league,liga portugal,eredivisie
# 2026-05-27: Football ML promote filter (audit shadow 28d n=98: EV 10-20% ROI +20%
# gap +2pp; top5+UCL/UEL+Brasileirão A whitelist; Brasileirão B excluído n=18 -25%).
# REQUER FOOTBALL_SHADOW=false (server senão rota tudo via _autoRouteToShadow).
# TENNIS_ML_PROMOTE_FILTER pattern (commit b795837) — mesmo template.
# FOOTBALL_ML_PROMOTE_FILTER=false        # true → ativa filter; non-match → shadow
# FOOTBALL_ML_PROMOTE_EV_MIN=10            # EV mínimo (%) para promover
# FOOTBALL_ML_PROMOTE_EV_MAX=20            # EV máximo (%) — >20 não testado (audit cobriu 10-20)
# FOOTBALL_ML_PROMOTE_LEAGUES=premier league|la liga|bundesliga|serie a|ligue 1|champions league|europa league|brasileir.{1,4} s.rie a    # regex whitelist (default top5 + UCL/UEL + Brasileirão A)
VALORANT_ML_TIER1_LEAGUES=vct,masters,champions,game changers

# Valorant: gate sample mínimo per team em tier 2/3 (Challengers regional).
# Default 40 — abaixo disso modelo elo overcalla quando Pinnacle tem info
# que elo não captura (form/roster/scrim leaks). Audit 2026-05-17: Challengers
# Spain shadow 60d ROI -76% n=10, gate teria bloqueado 6/10 (todas losses).
# Tier 1 (Champions Tour) inalterado pelo gate.
VAL_NON_TIER1_MIN_GAMES=40

# ─────────────────────────────────────────────────────────────────────────
# MT scaling — recovery de leaks via per-market amplification
# ─────────────────────────────────────────────────────────────────────────
# CS2 MT total +15,7% n=40 hit 59% CLV+12 ⭐ — scale stake.
CS2_MT_TT_MIN_EV=5                         # default 8; captura edges 5-8% (n=51 valida)
CS2_TOTAL_STAKE_MULT=1.3                   # +30% stake em totals cs2; cap 2.0×
# Dota2 MT total +64,9% n=10 hit 71% CLV+10,63 ⭐ — small sample mas forte.
DOTA2_TOTAL_STAKE_MULT=1.2                 # +20% stake; conservador até n≥30
# LoL MT handicap +45,9% n=10 hit 86% — relax gate.
LOL_MT_HC_MIN_EV=6                         # default 8; captura handicap edges 6-8%
LOL_HANDICAP_STAKE_MULT=1.2                # +20% stake em handicap LoL
# Tennis HG +30,5% real (n=41) vs shadow -2,5% n=340 → tighten min_ev.
TENNIS_HG_MIN_EV=12                        # default 8; força edge >12% (filter agressivo)

# ── Edge-shrink (anti-adverse-selection, audit 2026-05-29) ──────────────────
# Anchor model prob toward the devigged FAIR line BEFORE EV: p_used = fair + s*(model-fair).
# s=1 (default) = trust model fully (NO-OP); s=0 = pure market follower (no bets); s in (0,1)
# shrinks overconfident high-EV picks the MOST (counters the EV gate selecting model errors).
# Fit the per-segment optimum via GET /admin/edge-shrink-fit before enabling.
# Hierarchy: TENNIS_<TAG>_EDGE_SHRINK > TENNIS_MT_EDGE_SHRINK > 1.0. Tags: HG/TG/ACES/TB.
# TENNIS_MT_EDGE_SHRINK=1.0
# TENNIS_HG_EDGE_SHRINK=0.5                 # handicapGames (most adverse-selected market)
# TENNIS_TG_EDGE_SHRINK=0.5                 # totalGames
# TENNIS_MT_DEVIG_METHOD=auto               # auto (no-op) | shin | power | multiplicative

# ─────────────────────────────────────────────────────────────────────────
# Self-healing + EV calib refit
# ─────────────────────────────────────────────────────────────────────────
AUTO_SHADOW_NEGATIVE_CLV=true              # flipa sport pra shadow auto quando CLV avg < -1% n≥30 (cron 6h)
TIME_OF_DAY_AUTO=true                      # bloqueia hora UTC com ROI persistentemente <-25% n≥8 (per-sport cache 1h)
EV_CALIB_DAYS=90                           # 60→90 (mais sample → menos ruído de bucket)
EV_CALIB_REFRESH_MS=10800000               # 3h vs 6h (react mais rápido a regime change)
FB_DIVERGENCE_MAX_PP=8                     # 12→8 (corta tips com modelo discrepante de Pinnacle close)

# ─────────────────────────────────────────────────────────────────────────
# Analytics Watchdog (DuckDB metrics auto-monitor)
# ─────────────────────────────────────────────────────────────────────────
# Cron 6h roda 12 métricas DAX, dispara DM admin quando thresholds breached.
# Throttle 24h por (rule, sport) via tabela analytics_alerts (mig 081).
ANALYTICS_WATCHDOG_AUTO=true                # default ON
ANALYTICS_WATCHDOG_INTERVAL_H=6             # horas entre checks
WATCHDOG_DAYS=30                            # janela default
WATCHDOG_COOLDOWN_HOURS=24                  # não realertar mesma rule+sport
WATCHDOG_AUTO_RESOLVE_DAYS=7                # auto-resolve alerts open > N dias (default 7, bumped from 30 in 2026-05-16)
# Thresholds (override defaults audit-driven):
# WATCHDOG_SHARPE_MIN=0                     # sharpe < X = alert
# WATCHDOG_DD_MAX_PCT=-25                   # max_dd_pct ≤ X = alert
# WATCHDOG_CALIB_MAX_GAP_PP=8               # |calib_gap| > X pp = alert
# WATCHDOG_TILT_LOSS_MIN=4                  # current loss streak ≥ X = alert
# WATCHDOG_CLV_MIN_PCT=-1                   # avg_clv < X% n≥30 = alert
# WATCHDOG_EV_LEAK_ROI=-15                  # bucket >12% ROI < X% = alert
# WATCHDOG_MATRIX_ROI_MIN=-25               # market×sport ROI < X% n≥15 = alert

# Daily digest (snapshot 1×/dia, hora UTC configurável).
ANALYTICS_DIGEST_AUTO=true                  # default ON
ANALYTICS_DIGEST_HOUR_UTC=12                # 12 UTC = ~9h BR
WATCHDOG_DIGEST_DAYS=7                      # janela mais curta = mais sensível

# PnL Daily Report (notificação 1×/dia: hoje + 7d + 30d + total).
# 2026-05-21: default mudou 9 UTC matinal → 21h BRT (0 UTC). Hardcoded em bot.js
# como PNL_DAILY_BR_HOUR='21' default; override só via env explícito abaixo.
PNL_DAILY_AUTO=true                         # default ON
# PNL_DAILY_BR_HOUR=21                      # default 21h BRT (= 0 UTC) — prevalece
# PNL_DAILY_HOUR_UTC=0                      # fallback UTC se BR_HOUR inválido

# ─────────────────────────────────────────────────────────────────────────
# Drawdown thresholds per-sport (audit log 2026-05-04)
# ─────────────────────────────────────────────────────────────────────────
# Tennis recovery: bankroll 69.75/100 (-30%) mas market HG +26,6% ROI 14d
# (+R$5,80 net). Hard limit 25% travava recovery. Override 40% destrava
# emissão com taper ×0.35 protegendo risco.
DRAWDOWN_HARD_LIMIT_TENNIS=0.40             # tennis recovery: 25→40%
DRAWDOWN_TAPER_LIMIT_TENNIS=0.32            # tennis taper kick-in 20→32%
# Geral (sports sem override): mantém defaults
# DRAWDOWN_HARD_LIMIT=0.25                  # default global
# DRAWDOWN_TAPER_LIMIT=0.20                 # default global
# DRAWDOWN_SOFT_LIMIT=0.15                  # default global

# ─────────────────────────────────────────────────────────────────────────
# Wave 1 MT extensions (audit 2026-05-14) — CS rounds + Basket per-quarter
# ─────────────────────────────────────────────────────────────────────────
# CS2 rounds-level scanner (handicap_rounds + total_rounds per-map).
# Modelo: Normal(μ, σ) round-diff em lib/cs-rounds-model.js. Pinnacle expõe
# spread+total em period=1..csBestOf (Bo3=3 mapas). Shadow-only Wave 1.
CS_ROUNDS_SCAN=1                            # 1/true ativa; 0/false desativa scanner
CS_ROUNDS_SHADOW=true                       # true bloqueia promote real (Wave 1 default; flip pra false ativa Wave 2 promote)
CS_ROUNDS_MIN_EV=4                          # gate EV mínimo shadow
CS_ROUNDS_MAX_EV=30                         # cap EV ceiling (anti-mispricing)
CS_ROUNDS_MIN_PMODEL=0.50                   # gate pModel mínimo shadow
CS_ROUNDS_MAX_PER_MATCH=3                   # top-K por EV per period
# Wave 2 promote gates (efeito quando CS_ROUNDS_SHADOW=false + granular promote DB)
CS_ROUNDS_TIP_MIN_EV=6                      # gate EV mínimo promote (mais conservador que shadow)
CS_ROUNDS_TIP_MIN_PMODEL=0.55               # gate pModel mínimo promote

# Valorant rounds-level scanner (handicap_rounds + total_rounds per-map).
# Modelo delegate cs-rounds-model via lib/valorant-rounds-model.js. Shadow-only Wave 2A.
VAL_ROUNDS_SCAN=1                           # 1/true ativa; 0/false desativa scanner
VAL_ROUNDS_SHADOW=true                      # true bloqueia promote real; flip pra false ativa Wave 2 promote
VAL_ROUNDS_MIN_EV=4                         # gate EV mínimo shadow
VAL_ROUNDS_MAX_EV=30                        # cap EV ceiling
VAL_ROUNDS_MIN_PMODEL=0.50                  # gate pModel mínimo shadow
# Wave 2 promote gates (efeito quando VAL_ROUNDS_SHADOW=false + granular promote DB)
VAL_ROUNDS_TIP_MIN_EV=6                     # gate EV mínimo promote
VAL_ROUNDS_TIP_MIN_PMODEL=0.55              # gate pModel mínimo promote

# Basket per-quarter scanner (NBA Q1..Q4 totals + spreads).
# Trained model μ/σ re-escalado pra quarter scope (μ_q=μ_full/4, σ_q=σ_full/2).
# Pinnacle expõe period=1..4. Shadow-only Wave 1.
BASKET_QUARTER_SCAN=1                       # 1/true ativa; 0/false desativa
BASKET_QUARTER_SHADOW=true                  # true bloqueia promote real (Wave 1 default; flip pra false ativa Wave 2 promote)
BASKET_QUARTER_MIN_EV=5                     # gate EV mínimo shadow
BASKET_QUARTER_MAX_EV=30                    # cap EV ceiling
BASKET_QUARTER_MIN_PMODEL=0.50              # gate pModel mínimo shadow
# Wave 2 promote gates (efeito quando BASKET_QUARTER_SHADOW=false + granular promote DB)
BASKET_QUARTER_TIP_MIN_EV=7                 # gate EV promote (mais alto: variance per-quarter NBA maior)
BASKET_QUARTER_TIP_MIN_PMODEL=0.55          # gate pModel promote

# Football 1H Markets scanner (1H ML + 1H totals + 1H BTTS).
# Modelo Poisson sub-rate 0.42 (top-5 leagues empirical) em lib/football-1h-model.js.
# Pre-game only (!isFbLive). Wave 2B (commit d20764b).
FB_1H_SCAN=1                                # 1/true ativa; 0/false desativa scanner
FB_1H_SHADOW=true                           # true bloqueia promote real; flip pra false ativa Wave 2 promote
FB_1H_MIN_EV=5                              # gate EV mínimo shadow
# Wave 2 promote gates (efeito quando FB_1H_SHADOW=false + granular promote DB)
FB_1H_TIP_MIN_EV=6                          # gate EV promote
FB_1H_TIP_MIN_PMODEL=0.55                   # gate pModel promote

# ─────────────────────────────────────────────────────────────────────────
# Audit robustez 2026-05-15 — defense-in-depth + perf envs
# ─────────────────────────────────────────────────────────────────────────
LOG_CLIENT_MAX=20                           # SSE log clients cap (OOM防, clamp 1-500)
ESPN_CONCURRENCY=8                          # paralelização getUpcomingMatches/getFinishedMatches basket+soccer
HLTV_RETRY_ATTEMPTS=3                       # retries fetchFirstHtml (clamp 1-5; backoff 700ms→2s→5s + jitter ±20%)
CORS_ALLOWED_ORIGINS=*                      # csv allowed origins; '*' default backward-compat. Strict: 'https://app.com,https://admin.app.com'
ADMIN_RATE_LIMIT_PER_MIN=60                 # req/min/IP cross-admin (defense-in-depth via requireAdmin; clamp 10-600)
KELLY_PRODUCT_CAP_FRAC=0.15                 # cap product Kelly fraction após mults (CLV×trust×autotune×tier×steam). Default 1.5× MAX_KELLY_FRAC SAGRADO. Set high (99) pra desativar — perda do gate cross-sport DoS防

# Sprint cleanup — bucket_block P2 enforcement (2026-05-15):
# Block é SINTOMA (rejeita real tip emission) → trigger source = real (P2).
# Default true alinha com pattern Wave 2 (EV_CALIB_REAL_ONLY etc).
# Opt-out false reverte pra shadow-trigger legacy (P2 violation).
ML_BUCKET_BLOCK_REAL_ONLY=true              # default; false = legacy shadow trigger
ML_BUCKET_BLOCK_REAL_MIN_N=5                # min sample real pra trigger (acomoda volume menor)

# Sprint 4 #1: cron-stagger ativo por default — crons sharing same hour
# fire em minutos staggered (deterministic hash) pra prevenir stampede.
# 5 crons em 4h UTC: bankroll_reconcile=min8, readiness_retention=29,
# threshold_auto_apply=36, db_backup=43, db_integrity_check=49.
# Set false pra legacy behavior (all fire at minute 0 of hour).
# CRON_STAGGER=false                         # opt-out (default true)

# Sprint 4 #2: cross-process memory critical signal via shared files.
# Default: project root. Override pra /tmp ou /data se prod usa volume separado.
# MEM_SHARED_DIR=/tmp                         # dir pra _mem_critical_<process>.json

# Audit 2026-05-15 restart loop fix: per-process heap caps em start.js spawn.
# V8 default heap_size_limit ~4GB (unbounded vs Railway 512MB). Sem cap, bot
# crescia ~46 MB/h até container OOM @ ~5h. Fix força V8 GC aggressive antes
# cap → "JavaScript heap OOM" catchable vs SIGKILL silent. Budget cap 512:
# launcher 50 + server 200 + bot 260 = ~510 RSS combined.
BOT_HEAP_MB=180                             # bot.js --max-old-space-size (default 180)
SERVER_HEAP_MB=200                          # server.js --max-old-space-size (default 200; era 150 — 2026-05-16 OOM SIGABRT em JSON parse cumulative)

# Memory leak workaround (2026-05-22 audit log)
# CRON-MEM warn detectou Δrss=+108MB per cron consistente (Δheap só +9-54MB)
# → non-heap leak (V8 LargeObject + Buffer chunks + glibc fragmentation pós
# Sofa JSON parse 2-5MB bodies). --expose-gc habilita global.gc() forçado em
# cron handler quando spike detectado. Mede e libera non-heap.
# DISABLE_EXPOSE_GC=true                     # opt-out (default OFF = --expose-gc ativo)
# FORCE_GC_AFTER_CRON_MEM=false              # opt-out trigger gc no CRON-MEM warn

# DB integrity check (PRAGMA integrity_check). Detecta WAL stale, OOM corruption.
# 2026-05-16: gate daily 1x/dia → interval cada N horas. Corrupção pós-OOM
# (caso 14:48-15:08 UTC) ficava invisível até próximo cron diário (~24h gap).
# DB_INTEGRITY_CHECK_AUTO=true               # default true; false desliga cron
# DB_INTEGRITY_CHECK_INTERVAL_HOURS=4        # default 4h; 5-15s × 6/dia = ~1min I/O
# BOOT_INTEGRITY_SYNC=true                   # blocking integrity check on boot (default false — async 30s)

# DB size alert threshold. Volume cost Railway negligível ($0.09/mês pra 332MB).
# Default 500MB cobre crescimento organic sem false alarms. Bump se DB legítimo
# cresce muito (match_results historical, oracleselixir stats — ambos load-bearing
# pra ELO/predições). VACUUM só ajuda pós-DELETE (freelist vazio = no reclaim).
DB_SIZE_ALERT_MB=500                        # warn em /health alerts se > N MB

# Bankroll integrity defense-in-depth (audit 2026-05-15 architectural)
# Spec: docs/superpowers/specs/2026-05-15-bankroll-integrity-design.md
BANKROLL_RECONCILE_AUTO=true                # cron daily reconciliation (component E)
BANKROLL_RECONCILE_HOUR_UTC=4               # hora UTC daily run (fires em min 8 via stagger)
BANKROLL_RECONCILE_THRESHOLD=0.10           # R$ drift threshold > 0 dispara DM admin + grava bankroll_drift_log
SETTLE_GAP_DETECTOR_AUTO=true               # cron daily settle gap detector (component C)
SETTLE_GAP_HOUR_UTC=5                       # hora UTC daily run (após reconcile)
SETTLE_GAP_WINDOW_DAYS=30                   # janela busca shadow settled sem propagação correspondente

# match_result_sources cleanup (audit 2026-05-16: tabela cresce ~800K/dia sem TTL;
# 1.6M rows = 95% do DB size em 2d). Mig 109 FASE 1 só precisa últimos 7d pra
# reconcile cron — retention 30d = margem segura pra debug pós-hoc.
MATCH_RESULT_SOURCES_CLEANUP_AUTO=true       # cron daily cleanup
MATCH_RESULT_SOURCES_CLEANUP_HOUR_UTC=5      # hora UTC daily run (pareia com settle_gap)

# LoL fallback path (AI_DISABLED / deepseek backoff). Audit memory
# project_tip_emission_audit_2026_05_15 identificou min_ev=5 + min_edge=5 strict
# bloqueando positive-edge longshots (ZeroZone @3.57 edge 11.1pp rejected).
# Default mantido em 5/5 — só loosen quando A/B-test confirmar positive ROI sustenta.
# Mirror DOTA_FALLBACK_MIN_EV (que já existia, default 5).
LOL_FALLBACK_MIN_EV=5                        # min EV pct pra fallback emitir (default 5)
LOL_FALLBACK_MIN_EDGE=5                      # min ML edge pp pra fallback emitir (default 5)

# DeepSeek throttle / backoff cross-path (main LoL AI + _runAiShadow shared state).
# 2026-05-21 audit log: burst 7 football matches → 7x 429 em ~70s. Shadow path
# antes ignorava backoff do main path. Agora compartilham __deepseekBackoffUntil global.
# DEEPSEEK_BACKOFF_MS=180000                 # default 3min — TTL backoff em 429
# DEEPSEEK_CALL_COOLDOWN_MS=20000            # cooldown preventivo entre calls main path (default 20s)
# DEEPSEEK_COOLDOWN_MAX_WAIT_MS=25000        # cap espera no main path (skip se cooldown > MAX)

# Stuck-pending early-warning per-sport (audit 2026-05-16: dota2 single-source
# PandaScore = silent fail risk se feed cair). Cron 1h DM admin quando ≥minN
# tips pendentes > warn_H, ANTES do auto_void em 36h. Cooldown 12h per sport.
STUCK_PENDING_WARN_AUTO=true                 # default ON
STUCK_PENDING_WARN_COOLDOWN_H=12             # cooldown DM per sport
STUCK_PENDING_WARN_MIN_N=2                   # min tips pendentes pra alertar
STUCK_PENDING_WARN_H_DOTA2=12                # dota2 (single-source settle) — alerta agressivo
STUCK_PENDING_WARN_H_LOL=18                  # lol (Riot+PS dual-source) — alerta moderado
STUCK_PENDING_WARN_H_CS=18                   # cs/cs2 (HLTV+PS dual-source)
STUCK_PENDING_WARN_H_CS2=18                  #
STUCK_PENDING_WARN_H_VALORANT=18             # valorant (PS only — single-source risk similar dota2)
STUCK_PENDING_WARN_H_TENNIS=18               # tennis (ESPN+Sackmann+Sofa)

# Live odds drift guard (audit adversarial 2026-05-16 #1). Tennis tem inline
# check em bot.js:18861 (driftPct>12). Outros sports adopt via lib/utils.js
# checkLiveOddsDrift helper. Default 12pp = mirror tennis.
# Per-sport override: LOL_LIVE_DRIFT_PP, CS_LIVE_DRIFT_PP, DOTA_LIVE_DRIFT_PP, VALORANT_LIVE_DRIFT_PP
LOL_LIVE_DRIFT_PP=12                         # abort live LoL tip se drift > N pp (default 12)
CS_LIVE_DRIFT_PP=12                          # CS rounds podem mover 30%+ entre rounds
DOTA_LIVE_DRIFT_PP=12                        # Dota fights mudam odds rapidamente
VALORANT_LIVE_DRIFT_PP=12                    # Valorant rounds similar CS
MATCH_RESULT_SOURCES_RETENTION_DAYS=30       # delete rows > N days (min 7, max 180)
# 2026-05-28 audit-banco: retenção de telemetria live grande (anti-bloat DB; defaults já aplicam)
# LIVE_TELEMETRY_RETENTION_DAYS=60           # super_odd/book_bug/velocity/arb/stale_line/bookmaker_delta_samples (clamp 7-180)
# DOTA_LIVE_SNAPSHOTS_RETENTION_DAYS=30      # dota_live_snapshots, alto volume (clamp 7-90)
# DB_AUTO_VACUUM=on                          # auto_vacuum=INCREMENTAL (default on); off desliga. Requer 1 VACUUM full p/ ativar o modo num DB existente

# Dota2 MAP_WINNER live tip guards (bot.js:16824 / :16831). Pré-existentes;
# documentação .env.example pendente até P5 cross-sport audit 2026-05-18.
# EV ceiling rejeita ticks irreais (model error). Divergence guard rejeita
# |pick - implied| > N pp (modelo vs mercado discordando demais → edge fake).
# DOTA_MAP_EV_CEILING=40                       # rejeita pickEv > N% (default 40)
# DOTA_MAP_MAX_DIVERGENCE_PP=20                # rejeita |divergence| > N pp (default 20)

# Pinnacle follower (bot.js:26800-26823 path). Opt-in path que captura tip em
# book lagging quando Pinnacle dropa fast (sharp money entered). Pré-existentes;
# documentação .env.example pendente até P5 cross-sport audit 2026-05-18.
# PINNACLE_FOLLOWER_ENABLED=false              # opt-in (default OFF — conservador)
# PINNACLE_FOLLOWER_MIN_DROP_PCT=3             # drop mínimo Pinnacle pra disparar (default 3%)
# PINNACLE_FOLLOWER_MIN_EV=5                   # EV mínimo no book lagging pra emit (default 5%)
# PINNACLE_FOLLOWER_STAKE=1                    # stake conservador units (default 1u)

# Soft-vs-sharp follower (Path 2, 2026-05-30 — lib/soft-vs-sharp + bot._tryEmitSoftVsSharpTip).
# Emite tip REAL quando casa SOFT paga acima da linha SHARP (Pinnacle) de-vigada — o +EV
# durável do diagnóstico de leak (model-vs-sharp é adverse-selected). Reusa detectSuperOdd
# (Pinnacle-anchor) dentro de runStaleLineCron; gate = EV estático + freshness no _capturedAt
# da entrada soft (feed BR pode ficar dias stale). Shadow-safe (isBucketShadowed → só tennis
# real; lol/football vão pra shadow). Sizing 100% server-side (/record-tip). DARK até reviver
# scraper BR + validar freshness no real.
# SOFT_VS_SHARP_ENABLED=false                  # opt-in master switch (default OFF)
# SOFT_VS_SHARP_MIN_EV=3                        # EV% mínimo vs linha sharp de-vigada (default 3)
# SOFT_VS_SHARP_MAX_AGE_MIN=15                  # idade máx do preço soft em min; acima = stale (default 15)
# SOFT_VS_SHARP_STAKE=1                         # stake conservador units (default 1u; server re-sizes via Kelly)

# CLV multi-window priority (P6 full, commit 07dd2e4). captureMarketTipsClv
# prioriza tips com kickoff dentro de N minutos (closing line consolidado).
# Tips fora da janela ordenam por created_at ASC (legacy fallback).
# Requer mig 115 (market_tips_shadow.match_start_at). Default 30min.
# CLV_CAPTURE_PRIORITY_WINDOW_MIN=30           # janela kickoff-proximity em minutos

# Health silent threshold tier-aware overrides (commit 7b8e82d). Defaults
# tier-aware em _STALE_HOURS_BY_TIER_DEFAULTS: lol/cs/dota2 tier1=24h tier2=48h
# tier3=72h other=96h. Valorant tier3=96h other=120h. Tennis: atp_main/wta_main=12h
# challenger/wta125k=48h itf=96h. Football: top5_uefa=12h br_serie_a/uefa=24h.
# Override hierarchy: HEALTH_LAST_TIP_STALE_HOURS_<SPORT>_<TIER> > HEALTH_LAST_TIP_STALE_HOURS_<SPORT>.
# HEALTH_LAST_TIP_STALE_HOURS_LOL_TIER3=48     # override agressivo tier3 LoL
# HEALTH_LAST_TIP_STALE_HOURS_VALORANT_TIER3=72  # override Spain Valorant
# HEALTH_LAST_TIP_STALE_HOURS_TENNIS_ATP_MAIN=8  # override agressivo ATP main

# Time-of-day blocking (server.js:25330+). Per-sport per-hour ROI bleeder block.
# Auto-detect via aggregação tips reais sport-wide. Defaults: MIN_N=8 sport-wide,
# MIN_N_MARKET=4 per-(hour,market), ROI_MAX=-25%. Override pra testing:
# TIME_OF_DAY_AUTO=true                        # ativa (default OFF)
# TIME_OF_DAY_MIN_N=8                          # min settled tips em hora pra bloquear (sport-wide)
# TIME_OF_DAY_MIN_N_MARKET=4                   # min settled tips per (hour,market)
# TIME_OF_DAY_ROI_MAX=-25                      # bloqueia hora se ROI <= N%

# Match stop-loss (server.js:25597). Bloqueia novas tips em série quando perdas
# acumulada na mesma série (últimas 6h) ≥ N units. Reduz tilt amplification.
# Default 0 = OFF. Recomenda 2u pra esports Bo3/Bo5.
# MATCH_STOP_LOSS_UNITS=2                       # ativa stop-loss (units)

# ML bucket block hard reject (server.js:25295). Bypassa _autoRouteToShadow,
# rejeita tip diretamente em vez de redirecionar. Default false (auto-shadow).
# ML_BUCKET_BLOCK_HARD_REJECT=false             # opt-in hard reject

# SEG-3 (audit adversarial): /record-tip shared-secret token. Antes endpoint
# era PUBLIC unauth — atacante via Railway URL podia injetar tips bypass bot.js.
# Opt-in gradual: set ambos vars em bot+server, verify logs, depois REQUIRED=true.
# Bot.js inclui x-record-tip-token header se RECORD_TIP_TOKEN set.
# RECORD_TIP_TOKEN=<random-uuid>                # shared secret bot↔server
# RECORD_TIP_TOKEN_REQUIRED=false               # opt-in 401 enforcement

# P3 isotonic brier holdout eval (commit 368dfda). refresh-all-isotonics.js
# captura brier pre/pós-fit em shadow sample (lib/brier-holdout-eval). Se
# brier_post > brier_pre * (1 + PCT/100), rollback automático.
# ISOTONIC_BRIER_REGRESSION_THRESHOLD_PCT=5    # threshold % piora pra rollback
# ISOTONIC_HOLDOUT_DAYS=14                      # janela holdout sample (dias)
# ISOTONIC_HOLDOUT_MIN_N=30                     # min samples shadow pra eval

# P1.A MT-EV-CAP per (sport, market) defaults — audit log 2026-05-18 mostrou
# 3× MT-EV-CAP tennis em 13min (handicapGames @ 10.7 EV 282%). Tennis Markov
# calib em odds extremas overshoot. Default 30% pra tennis/{handicapGames,
# totalGames}; demais sports/markets continuam 50% global. Override hierarchy:
# MT_EV_CAP_<SPORT>_<MARKET> > MT_EV_CAP_<SPORT> > MT_EV_CAP_PCT > defaults.
# MT_EV_CAP_TENNIS_HANDICAPGAMES=30            # override agressivo handicap tennis
# MT_EV_CAP_TENNIS_TOTALGAMES=30                # override total tennis

# P1.B tennis auto-void Challenger/Doubles/ITF stale (audit log SETTLE-TENNIS
# unsettled crescendo 92→103→104+ — doubles ESPN não cobre, Challenger
# Sackmann name mismatch). Cron settle-tennis voida tips >24h sem match em
# eventos Challenger/Doubles/ITF/W125. Profit=0, result=void, settled_at=now.
# Opt-out: TENNIS_AUTO_VOID_CHALLENGER_DOUBLES_DISABLED=true.
# TENNIS_CHALLENGER_DOUBLES_VOID_HOURS=24      # threshold horas pra void (12-72)
# TENNIS_AUTO_VOID_CHALLENGER_DOUBLES_DISABLED=false  # opt-out (default ativo)

# ─────────────────────────────────────────────────────────────────────────
# Session 2026-05-20 — group dispatch + AI gates + tennis ingest mit + per-map
# ─────────────────────────────────────────────────────────────────────────

# Telegram group subscription (envs novos commit 9b6cca5)
# Adicionar bot a um grupo + setar chat_id negativo aqui:
# TELEGRAM_GROUP_CHAT_IDS_ALL=-1001234567890           # CSV, todos sports habilitados
# TELEGRAM_GROUP_CHAT_IDS_LOL=-1001234567890           # per-sport (alternativa)
# TELEGRAM_GROUP_CHAT_IDS_TENNIS=-1001234567890

# Broadcast MT tips pra subscribed groups (commit 907a524)
# Default true: tips com 'tip' no context (MT/kills/rounds/etc) replica nos groups.
# Non-tip contexts (audit/calib/digest/watchdog) ficam admin-only.
# TIPS_BROADCAST_TO_GROUPS=true                # =false desabilita

# Periodic subscribers refresh (commit 6763702)
# Hot-reload subscribedUsers do DB a cada N ms (sem precisar restart).
# Default 5min. Clamp ≥30000ms. =0 desabilita.
# SUBSCRIBERS_REFRESH_INTERVAL_MS=300000

# AI min odd floor gate (commit e86f807)
# Filtra tips AI com odd < threshold ANTES de emit. Default 1.40 (mirror MT_MIN_ODD).
# Per-sport override granular:
# LOL_AI_MIN_ODDS=1.50                         # mais restritivo LoL
# MMA_AI_MIN_ODDS=1.30                         # MMA favorito pesado OK
# *_AI_MIN_ODDS=0                              # disable gate (não recomendado)

# AI P validation hard+soft cross-sport (commit 890dc7a, 2026-05-22)
# _runAiShadow valida P_IA vs modelP em todos sports (LoL tem gate próprio).
# HARD skip se diff > AI_P_MAX_DIVERGENCE_PP. Default 15pp (esports/tennis/football),
# 20pp MMA (modelo é só record histórico, IA legitimamente desvia mais).
# SOFT downgrade conf se 8pp < diff <= maxPp.
# AI_P_MAX_DIVERGENCE_PP=15                    # global default (override por sport)
# AI_P_SOFT_DOWNGRADE_PP=8                     # threshold soft downgrade conf
# AI_P_VALIDATION_DISABLED=                    # =true preserva A/B test pré-refit
# <SPORT>_AI_P_MAX_DIVERGENCE_PP=20            # per-sport override (TENNIS/MMA/etc)

# AI EV cap defensive path REAL only (commit 1a45897, 2026-05-22, P2-safe)
# Skip real emit se EV > cap. Shadow continua puro coletando.
# Default 40 esports/tennis/football, 50 MMA. Set 0/-1 = off.
# AI_REAL_MAX_EV=40                            # global default
# <SPORT>_AI_REAL_MAX_EV=50                    # per-sport override

# Valorant prob shrink toward implied (2026-05-22 audit shadow learning)
# Valorant Elo+trained modelP calib gap -17.4pp em shadow 30d (n=85).
# Refit Markov não disponível (sport sem Markov MT model). Shrink workaround:
# modelP1_new = impliedP1 + (modelP1 - impliedP1) × VALORANT_PROB_SHRINK
# Range: 0 (full shrink = implied) ... 1.0 (no shrink, default).
# Sugestão start: 0.85 (15% shrink). Validar 14d shadow antes de subir prod.
# VALORANT_PROB_SHRINK=0.85

# CSA — Cross-Significance Analyzer daily cron (Fase 2, 2026-05-22)
# Roda CSA daily (default 24h), DM admin alerts NEW_EDGE / NEW_LEAK / TO_ARM_CLOSE.
# P2-compliant: read-only sugestão, decisão humana. Dedup in-memory cross-cycle.
# CSA_AUTO=true                              # master switch (default true)
# CSA_INTERVAL_H=24                          # frequencia (clamp 6-72)
# CSA_SPORTS=tennis,lol                      # CSV sports (Fase 3 vai expandir)
# CSA_DAYS=30                                # janela analise
# CSA_MIN_N=20                               # amostra minima por bucket
# CSA_RETENTION_DAYS=90                      # mig 124 snapshots retention (clamp 30-365)

# HTTP-LARGE warn allowlist (2026-05-22)
# Hosts conhecidos com bodies >2MB esperados (ESPN scoreboard, Sofascore schedule,
# HLTV proxy). Substring match em hostname. Default cobre 4 hosts observados em
# logs prod. Set vazio = sem allowlist (warn pra todos).
# HTTP_LARGE_BODY_WARN_ALLOWLIST=site.api.espn.com,api.sofascore.com,api.sofascore.app,pleasant-compassion-production,victorious-expression-production

# EV calib shadow fallback opt-in (2026-05-22 audit)
# Sports com <SPORT>_ML_SHADOW_ALL=true bloqueiam emit real → EV_CALIB_REAL_ONLY
# bloqueia calib usar shadow → ML calib n=0 (starvation circular). Fix: opt-in
# CSV lista sports que devem usar shadow universe pra refit calib.
# CLAUDE.md P2 permite: "Shadow data PODE alimentar: Calibration refit".
# Stake shadow ("1u") normalizado pra units scale — distorção mínima ratio-based.
# EV_CALIB_FALLBACK_SHADOW_SPORTS=tennis,mma   # CSV opt-in (default vazio = OFF)

# AI shadow audit cron (commit 603879c, 2026-05-22)
# Cron 24h DM admin se AI tips per sport degradarem (P2-safe, DM-only).
# AI_SHADOW_AUDIT_AUTO=true                    # master switch (default true)
# AI_SHADOW_AUDIT_INTERVAL_H=24                # frequencia (clamp 6-72)
# AI_AUDIT_WINDOW_DAYS=30                      # janela analise
# AI_AUDIT_ROI_FLOOR=-15                       # ROI abaixo = alerta
# AI_AUDIT_EV_CEILING=30                       # avgEV acima = alerta
# AI_AUDIT_MIN_N=20                            # amostra minima settled

# Tennis ESPN ingest mitigation #2+#3 (commits 56709a1, e74e4a5)
# Global rate-limit cross-anchor pra recentSpan + ToMatchResults paths (cron).
# NÃO afeta mais syncTennisEspnCompletedAroundSentAt — vide commit fb258c2 (audit P1-5).
# Default 120s. Clamp [30s, 600s].
# TENNIS_ESPN_ANY_WINDOW_MIN_MS=120000

# Tennis ESPN per-tip path opt-in throttle (commit fb258c2 — audit P1-5 externos)
# Antes 120s global causava starvation: 50 tips span 5 dias → 5 anchors → 1 sync.
# Removed por default. Setar >0 pra restaurar throttle (raro — só se ESPN rate-limita).
# TENNIS_ESPN_AROUND_GLOBAL_THROTTLE_MS=0

# Tennis ESPN per-anchor TTL (commit 5358c0e mit #1)
# Throttle por anchor key (per-tip-day). Default 600s (alinhado settle interval).
# Clamp [20s, 1800s].
# TENNIS_ESPN_WINDOW_SYNC_MIN_MS=600000

# Tennis ESPN scoreboard window per sync (commit 5358c0e mit #1)
# Defaults reduzidos 21→7 dias (window 42d→14d). Clamp [3, 50].
# TENNIS_ESPN_DATE_WINDOW_BEFORE_DAYS=7
# TENNIS_ESPN_DATE_WINDOW_AFTER_DAYS=7

# Void-old-pending cron — auto-void tips reais pending > N hours per sport
# Cron roda hourly; tips além do cutoff viram result=void profit_reais=0.
# Default 36h (esports/lol/cs/cs2/dota2/valorant/tennis/darts), 48h (snooker),
# 72h (mma), 192h (football), 24h (tabletennis).
# Bump VOID_STUCK_H_TENNIS=72 enquanto SETTLE-TENNIS gap não resolve.
# VOID_STUCK_H_TENNIS=72
# VOID_STUCK_H_LOL=36
# VOID_STUCK_H_CS=36
# VOID_STUCK_H_DOTA2=36
# VOID_STUCK_H_VALORANT=36
# VOID_STUCK_H_MMA=72
# VOID_STUCK_H_FOOTBALL=192
# VOID_STUCK_H_BASKET=36

# HLTV match_id blacklist after N fails (commit XX — audit P1 externos)
# (team1, team2) pair que falha N+ vezes consecutivas em getHltvMatchId fica
# blacklistado por M ms. Reduz log spam + load no proxy pra tier3 events que
# HLTV não indexa (ex: CCT Europe Challengers). Reset on first success.
# HLTV_MATCHID_BLACKLIST_THRESHOLD=5
# HLTV_MATCHID_BLACKLIST_MS=86400000

# Drift-triggered auto-refit calib (closed-loop bridge — audit 2026-05-24)
# Quando shadow-vs-real-drift detecta degradação severa, marca sport pra
# auto-refit calib em <30min (vs próximo schedule weekly). Cooldown 6h evita
# refit thrashing. P2-safe — refit é causa fix (não auto-block).
# DRIFT_TRIGGERED_REFIT_AUTO=true                # master switch, default ON
# DRIFT_TRIGGERED_REFIT_COOLDOWN_MS=21600000     # 6h cooldown per sport

# Calib stale auto-refit (2nd causa→fix bridge — mesmo commit)
# Cron 6h checa fittedAt dos calib JSON. Se age ≥ N dias → marca pending
# (drift bridge cron 30min consome). Captura modelo enviesado SEM drift signal
# explícito. Default 7 dias threshold (mais agressivo se prod observa staleness).
# CALIB_STALENESS_AUTO=true
# CALIB_STALENESS_THRESHOLD_DAYS=7

# ─────────────────────────────────────────────────────────────────────────
# Security hardening (2026-05-20)
# ─────────────────────────────────────────────────────────────────────────

# Admin failed-login lockout (anti-bruteforce ADMIN_KEY)
# Default: 10 falhas em 15min → lock IP por 30min.
# ADMIN_LOCKOUT_THRESHOLD=10                    # falhas pra trigger lock
# ADMIN_LOCKOUT_WINDOW_MS=900000                # janela de contagem (15min default)
# ADMIN_LOCKOUT_DURATION_MS=1800000             # duração do lock (30min default)

# IP allowlist pra admin endpoints (CSV de IPs/CIDR-24/16/8)
# Default vazio = todos IPs permitidos (legacy comportamento).
# ADMIN_IP_ALLOWLIST=192.168.1.0/24,10.0.0.5,201.123.45.67

# HexStrike anti-scanner defense (commit 694c211 + this)
# Detecta scanner tools (sqlmap/nuclei/gobuster/ffuf/hexstrike/etc) via UA,
# honeypot paths (/wp-admin, /.env, /phpmyadmin), e attack patterns (SQLi/XSS/path-traversal).
# IPs detectados são banned 24h (default). Override duração:
# HEXSTRIKE_BAN_HOURS=24                        # default 24h, range 1-720

# Pinnacle Brasil link (default br pós-regulação jul/2024)
# PINNACLE_REGION=int                           # 'int' ou 'com' volta pra pinnacle.com/pt

# Pinnacle AUTO-BET (commit 014c2a4 Phase 1 — scaffold + safety)
# ⚠️ FINANCEIRO — multi-layer safety mandatory:
# PINNACLE_AUTO_BET_ENABLED=false               # MASTER KILL SWITCH (default OFF)
# PINNACLE_AUTO_BET_DRY=true                    # DRY RUN default (Phase 1 sempre dry)
# PINNACLE_AUTO_BET_REQUIRE_CONFIRM=true        # Phase 2: Telegram approval before fire
# PINNACLE_MAX_STAKE_BRL=20                     # cap per bet (default conservador)
# PINNACLE_BET_UNIT_VALUE=1                     # 2026-05-21: valor R$/unit pra auto-bet REAL Pinnacle. Independente de stake_reais (dashboard). Setar 10 = bet R$10 por 1u (mantém dashboard tracking 1u=R$1). Default 1 (paridade)
# PINNACLE_DAILY_CAP_BRL=100                    # cap diário cross-bets
# PINNACLE_DAILY_CAP_COUNT=10                   # cap diário count
# PINNACLE_HOURLY_CAP_COUNT=3                   # rate limit per-hora
# PINNACLE_MIN_EV_PCT=5                         # rejeita auto-bet com EV<5%
# PINNACLE_USERNAME=                            # Phase 2: login pinnacle.com (Railway secrets!)
# PINNACLE_PASSWORD=                            # Phase 2: senha (Railway secrets!)
# PINNACLE_EXECUTOR_URL=                        # URL do executor worker (Phase 2)
# PINNACLE_EXECUTOR_TOKEN=                      # token compartilhado bot↔executor
# PINNACLE_EXECUTOR_TIMEOUT_MS=90000            # bot timeout pro POST executor (2026-05-21 P1-5: 30→90s)
# PINNACLE_MAX_SLIPPAGE_PCT=2                   # max % odd shift DOWN (positive slip sempre aceito após audit P1-4)
# Per-sport auto-bet allow/block (audit ROI 2026-05-21 sweet spots vs leaks):
# PINNACLE_AUTO_BET_SPORTS_BLOCK=lol,basket     # bloqueia leaks (LoL AI -42.7%, basket sample-1 -53%)
# PINNACLE_AUTO_BET_SPORTS_ALLOW=tennis,dota2,cs # restrict-allow (opcional, default vazio = todos permitidos)
# Executor service envs (deploy scripts/pinnacle-executor-example.js):
# PINNACLE_EXECUTOR_PORT=3001                   # porta HTTP server
# PINNACLE_EXECUTOR_MODE=mock                   # mock|playwright|api
# PINNACLE_BASE_URL=https://www.pinnacle.com/pt/  # base login URL
# PINNACLE_EVENT_URL_TEMPLATE=https://www.pinnacle.com/pt/event/{event_id}
# PLAYWRIGHT_HEADLESS=true                      # false pra debug visual
# PINNACLE_API_KEY=                             # Phase 2.2 Pinnacle Public API (contractual)
# Status: GET /admin/pinnacle-auto-bet-status?key=<KEY>
# Confirm manual: POST /admin/pinnacle-bet-confirm?tip_id=N&ticket_id=X&actual_odd=Y&key=<KEY>

# HLTV proxy + bulk results sync (commit 6d91140 Plan B)
# Popula match_results.match_id='hltv_*' rows via scrape /results pages.
# Habilita downstream cs-per-map-ingest pra ter HLTV matchIds diretos.
# HLTV_PROXY_BASE=                              # Railway worker FastAPI separado
# HLTV_DIRECT=false                             # true = direct www.hltv.org (CF likely block)
# HLTV_RESULTS_SYNC_AUTO=true                   # cron 1x/dia bulk sync /results
# HLTV_RESULTS_SYNC_HOUR_UTC=3                  # hora daily run (3h UTC = 0h BRT)
# HLTV_RESULTS_SYNC_PAGES=5                     # pages × 100 matches por run (default 5)
# Manual: POST /admin/sync-hltv-results?maxPages=5&key=<KEY>

# CS per-map rounds ingestion cron (commit a81c04a + cron wire)
# Popula match_results.result_meta_json com per-map round scores via HLTV proxy.
# Habilita settle automático de handicap_rounds_mapN + total_rounds_mapN markets.
# CS_PERMAP_INGEST_AUTO=true                    # default ON, opt-out =false
# CS_PERMAP_INGEST_DAYS=14                      # janela ingestion (default 14d)
# CS_PERMAP_INGEST_LIMIT=20                     # max matches por ciclo (rate-limit HLTV)
# Manual trigger: POST /admin/sync-cs-per-map-rounds?days=14&limit=50&key=<KEY>

# Valorant per-map rounds ingestion cron (commit 49c692e — mirror CS via VLR.gg)
# VAL_PERMAP_INGEST_AUTO=true                   # default ON, opt-out =false
# VAL_PERMAP_INGEST_DAYS=14                     # janela ingestion (default 14d)
# VAL_PERMAP_INGEST_LIMIT=15                    # max matches por ciclo (rate-limit VLR 2s)
# Manual trigger: POST /admin/sync-valorant-per-map-rounds?days=14&limit=30&key=<KEY>

# Settle notification — imagem custom em win streak (commit 85589b5)
# Quando user atinge N+ greens consecutivos, troca imagem default tip_win.jpg
# por tip_win_streak.jpg + adiciona banner 🔥 N GREENS CONSECUTIVOS!
# Streak cross-sport (todos sports juntos). Void/push não quebram.
# TIP_WIN_STREAK_THRESHOLD=3                    # default 3, mínimo 2
# TIP_SETTLE_NOTIFY_DISABLED=                   # 'true' desativa todas settle notifications

# Match ID alias resolver (commit ad9814a — mig 126 + lib/match-id-resolver)
# Fuzzy lookup pra tips com match_id 'agg_<slug>' (aggregator BR) que NUNCA
# bate match_results canonicalizado (espn_/sofa_/api_). Resolve via team1/team2
# Jaccard tokens >=3 + janela data ±N dias. Audit via /admin/alias-audit.
# MATCH_ID_ALIAS_MIN_SCORE=0.80                 # threshold safety (0..1), default 0.80
# MATCH_ID_ALIAS_DATE_WINDOW=2                  # ± dias pra fuzzy match (default 2, max 7)
