# в”Ђв”Ђ SportsEdge Bot вЂ” MMA Only (Fase 1) в”Ђв”Ђ

# Telegram
TELEGRAM_TOKEN_MMA=           # Token do bot MMA via @BotFather
TELEGRAM_TOKEN_TENNIS=        # Token do bot TГЄnis via @BotFather

# APIs
CLAUDE_API_KEY=               # Anthropic Claude (claude-sonnet-4-6)
ODDS_API_KEY=                 # OddsPapi free tier вЂ” MMA odds (oddspapi.io, 250 req/mГЄs)
THE_ODDS_API_KEY=             # The Odds API вЂ” futebol/tГЄnis/mma (the-odds-api.com, 500 req/mГЄs)
API_FOOTBALL_KEY=             # API-Football (api-sports.io) вЂ” fixtures sem odds, 100 req/dia grГЎtis
API_FOOTBALL_DAILY_BUDGET=80  # Buffer de seguranГ§a (padrГЈo 80 de 100)

# Cache HTTP (TTL por URL)
HTTP_CACHE_DEFAULT_TTL_MS=0              # 0=desligado (ainda faz dedupe in-flight)
HTTP_CACHE_MAX_ENTRIES=500               # limite entradas cache
HTTP_CACHE_THEODDS_TTL_MS=14400000       # 4h padrГЈo (The Odds API)
HTTP_CACHE_ODDSPAPI_TOURNAMENTS_TTL_MS=86400000  # 24h (lista tournaments)
HTTP_CACHE_ODDSPAPI_ODDS_TTL_MS=0        # odds OddsPapi (recomendado 0; backoff jГЎ controla)
HTTP_CACHE_ODDSPAPI_FIXTURE_TTL_MS=0     # odds-by-fixtures (handicap)

# Servidor
SERVER_PORT=3000
DB_PATH=/data/sportsedge.db  # Railway volume вЂ” use sportsedge.db localmente

# Admin
ADMIN_KEY=                    # Header: x-admin-key ou Authorization: Bearer (protege rotas admin)
ADMIN_USER_IDS=               # ID numГ©rico Telegram (obtenha via @userinfobot)

# Bucket gate (rejeita tips em faixas de odds com leak comprovado via roi-by-odds-bucket)
# Formato: "MIN-MAX" separado por vГ­rgula. MIN inclusive, MAX exclusive.
# ODDS_BUCKET_BLOCK=2.20-3.00              # cross-sport (default vazio)
# VALORANT_ODDS_BUCKET_BLOCK=2.20-99       # per-sport override (additive ao global)
# LOL_ODDS_BUCKET_BLOCK=3.00-99
# CS_ODDS_BUCKET_BLOCK=
# TENNIS_ODDS_BUCKET_BLOCK=
# DOTA2_ODDS_BUCKET_BLOCK=
# MMA_ODDS_BUCKET_BLOCK=
# FOOTBALL_ODDS_BUCKET_BLOCK=

# Bucket auto-guard (cron 12h, persiste em DB table odds_bucket_blocklist)
# Auto-block (sport, bucket) quando nв‰ҐminN AND ROIв‰¤cutoff AND CLVв‰¤clvCutoff. Auto-restore se ROI recupera.
# ODDS_BUCKET_GUARD_AUTO=true              # default true; setar false desativa o cron
# ODDS_BUCKET_GUARD_MIN_N=30
# ODDS_BUCKET_GUARD_ROI_CUTOFF=-10
# ODDS_BUCKET_GUARD_CLV_CUTOFF=-2
# ODDS_BUCKET_GUARD_ROI_RESTORE=-2
# ODDS_BUCKET_GUARD_DAYS=30

# Pre-match EV bonus (audit-leaks 2026-04-22 mostrou PRE-match com ROI muito
# pior que LIVE em vГЎrios sports вЂ” odds estГЎticas viram fantasma quando mercado
# move antes do start). Bonus Г© aditivo ao EV mГ­nimo jГЎ configurado per-sport.
# PRE_MATCH_EV_BONUS=                      # cross-sport (default 0)
# CS_PRE_MATCH_EV_BONUS=5                  # CS PRE -53% vs LIVE +19% (gap 72pp)
# VALORANT_PRE_MATCH_EV_BONUS=4            # Val PRE -44% vs LIVE +12% (gap 56pp)
# LOL_PRE_MATCH_EV_BONUS=4                 # esports PRE -37% vs LIVE +10% (gap 47pp)
# DARTS_PRE_MATCH_EV_BONUS=2               # Darts PRE +9% vs LIVE +49% (gap 40pp, marginal)
# DOTA2_PRE_MATCH_EV_BONUS=
# TENNIS_PRE_MATCH_EV_BONUS=               # tennis gap sГі 6pp, nГЈo justifica
# FOOTBALL_PRE_MATCH_EV_BONUS=

# Stake max cap (audit-leaks mostrou 3u tГіxico em esports/cs/tennis вЂ” modelo
# overconfident em casos extremos). Clamp final aplicado em applyGlobalRisk.
# MAX_STAKE_UNITS=2.0                      # cross-sport cap (default sem cap)
# CS_MAX_STAKE_UNITS=2.0                   # per-sport override
# ESPORTS_MAX_STAKE_UNITS=2.0              # equivalente a LOL no normSport
# LOL_MAX_STAKE_UNITS=2.0
# TENNIS_MAX_STAKE_UNITS=2.0
# DOTA2_MAX_STAKE_UNITS=
# VALORANT_MAX_STAKE_UNITS=

# Feature flags (MMA only por defeito)
MMA_ENABLED=true
ESPORTS_ENABLED=false
TENNIS_ENABLED=false          # true para ativar o bot de tГЄnis (requer TELEGRAM_TOKEN_TENNIS e THE_ODDS_API_KEY)
# TENNIS_MIN_ODDS=1.40        # Gate pГіs-IA: odd mГ­nima (default 1.40, alinhado ao MMA)
# TENNIS_MAX_ODDS=5.00        # Gate pГіs-IA: odd mГЎxima (default 5.00)
# TENNIS_ISOTONIC_DISABLED=true  # Kill-switch: bypassa lib/tennis-model-isotonic.json
                                 # (overshooting na zona [0.40, 0.55) вЂ” ROI -64% bucket 2.20-3.00)
                                 # NГЈo afeta isotonic interno do trained model (tennis-weights.json)

# Meta LoL
LOL_PATCH_META=                  # Ex: "Patch 15.6 вЂ” Azir/Corki meta mid, Garen top forte"
PATCH_META_DATE=                 # Ex: 2025-03-19 вЂ” auto-atualizado pelo bot via ddragon

# CalibraГ§ГЈo de thresholds (opcional вЂ” ajuste para mais ou menos tips)
# LOL_PREGAME_BLOCK_BO3=true     # true=sГі analisa Bo1 prГ©-jogo (maior qualidade) | false=analisa todos prГ©-jogo
# LOL_EV_THRESHOLD=1.5           # EV mГ­nimo para emitir tip (%) вЂ” padrГЈo 1.5, use 1.0 para mais tips
# LOL_PINNACLE_MARGIN=2.5        # Margem mГ­nima vs Pinnacle (pp) вЂ” padrГЈo 2.5, use 2.0 para mais tips
# LOL_NO_ODDS_CONVICTION=60      # ConvicГ§ГЈo mГ­nima sem odds (%) вЂ” padrГЈo 60, use 55 para mais tips
