# ─── Executor service config ────────────────────────────────────────────
PINNACLE_EXECUTOR_PORT=3001                       # HTTP server port
PINNACLE_EXECUTOR_TOKEN=                          # MESMO token que bot.env (use openssl rand -hex 32)
PINNACLE_EXECUTOR_MODE=mock                       # mock | playwright | api

# ─── Playwright mode credentials ────────────────────────────────────────
PINNACLE_USERNAME=                                # seu Customer ID Pinnacle
PINNACLE_PASSWORD=                                # senha (use Railway Secrets)

# ─── Pinnacle URL config ────────────────────────────────────────────────
PINNACLE_BASE_URL=https://www.pinnacle.com/pt/    # login URL (pt/br/en variantes)
PINNACLE_EVENT_URL_TEMPLATE=https://www.pinnacle.com/pt/event/{event_id}

# ─── Playwright runtime ─────────────────────────────────────────────────
PLAYWRIGHT_HEADLESS=true                          # false pra debug local visual
PLAYWRIGHT_UA=                                    # custom user-agent (default Chrome 131 Windows)
PLAYWRIGHT_STORAGE_PATH=/tmp/pinnacle-session.json # cookies + localStorage persist

# ─── API mode (Pinnacle Public API, contractual) ────────────────────────
PINNACLE_API_KEY=                                 # B2B contractual access only
