# Django Settings
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Database
DATABASE_URL=postgres://espn:espn@localhost:5432/espn_service

# Redis / Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
REDIS_URL=redis://localhost:6379/1

# ESPN Client
ESPN_SITE_API_URL=https://site.api.espn.com
ESPN_CORE_API_URL=https://sports.core.api.espn.com
ESPN_TIMEOUT=30.0
ESPN_MAX_RETRIES=3
ESPN_RETRY_BACKOFF=1.0
ESPN_USER_AGENT=ESPN-Service/1.0

# Sofascore Client (curl_cffi WAF bypass)
# Impersonation profile: chrome146 (latest, default), chrome145, chrome142, chrome136,
# safari260, firefox147, etc. Lista completa em curl_cffi/requests/impersonate.py.
# If Sofascore starts blocking the current profile, bump to a newer one.
# Histórico de bumps: chrome131 (deprecated 2026-05-16, ImpersonateError em prod),
# chrome124 (deprecated 2026-05-16, mesma falha), atual: chrome146.
SOFASCORE_IMPERSONATE=chrome146
# Per-path overrides (2026-05-17): Cloudflare WAF rules variam per esporte.
# Quando setado, prevalece sobre o global pra requests à URL com o esporte
# matching. Memory project_mma_sofascore_discovery_2026_05_16 confirmou:
# safari260 unlocks MMA enquanto chrome131/124 falham na mesma janela.
# Categorias detectadas via URL: mma, tennis, football, basketball, ice-hockey, esports.
# SOFASCORE_IMPERSONATE_MMA=safari260
# SOFASCORE_IMPERSONATE_TENNIS=chrome146
# SOFASCORE_IMPERSONATE_FOOTBALL=chrome124
SOFASCORE_TIMEOUT=12
# Optional residential proxy chain (e.g. Webshare) when datacenter IP is blacklisted.
# Format: http://user:pass@host:port  — leave empty to use Railway egress directly.
SOFASCORE_PROXY_URL=

# Logging
LOGGING_LEVEL=INFO

# Optional: Sentry (for production error tracking)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
ENVIRONMENT=development
